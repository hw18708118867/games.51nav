---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const pageTitle = 'About Brain Games Hub';
const pageDescription = 'Learn about Brain Games Hub — your free online brain training platform. Discover how our cognitive games help you test and improve your mental abilities.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />

  <main class="container">
    <section class="page-hero">
      <h1>About Brain Games Hub</h1>
      <p class="lead">Your free online brain training platform</p>
    </section>

    <section class="content-section">
      <h2>Our Mission</h2>
      <p>
        At Brain Games Hub, we believe that everyone should have access to tools that
        help them understand and improve their cognitive abilities. Our mission
        is to provide free, scientifically-inspired brain training games that
        are accessible to anyone with an internet connection.
      </p>
      <p>
        We offer a variety of cognitive tests and games that measure different
        aspects of brain function, including processing speed, memory, attention,
        and problem-solving skills. Each game is designed to be engaging while
        providing meaningful feedback about your performance.
      </p>
    </section>

    <section class="content-section">
      <h2>How It Works</h2>
      <div class="how-it-works">
        <div class="step">
          <span class="step-number">1</span>
          <h3>Choose a Game</h3>
          <p>Browse our collection of brain training games and pick one that interests you.</p>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <h3>Play &amp; Test</h3>
          <p>Each game measures a specific cognitive ability. Follow the instructions and give it your best effort.</p>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <h3>Track Progress</h3>
          <p>Your scores are saved automatically. Monitor your improvement over time and challenge yourself.</p>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2>Privacy &amp; Data</h2>
      <p>
        We take your privacy seriously. All game scores are stored locally on your
        device using your browser's localStorage. We do not collect, store, or
        transmit any personal data to our servers. You can clear your data at any
        time by clearing your browser's local storage.
      </p>
      <p>
        For more details, please read our <a href="/privacy-policy/">Privacy Policy</a>.
      </p>
    </section>

    <section class="content-section">
      <h2>Contact</h2>
      <p>
        Have questions, suggestions, or feedback? We'd love to hear from you!
        Please reach out to us at <a href="mailto:miraclehuang611@gmail.com">miraclehuang611@gmail.com</a>.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    text-align: center;
    padding: var(--space-16) 0 var(--space-8);
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .lead {
    font-size: var(--text-xl);
    color: var(--text-secondary);
  }

  .how-it-works {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .step {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--gradient-accent);
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: var(--text-xl);
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .step h3 {
    margin-bottom: var(--space-2);
  }

  .step p {
    font-size: var(--text-sm);
    margin-bottom: 0;
  }
</style>