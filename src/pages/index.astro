---
import { SITE_CONFIG } from '../lib/constants';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import GameCard from '../components/shared/GameCard.astro';
import { getCollection } from 'astro:content';
import type { GameMeta } from '../types/game';

const games = await getCollection('games');
const sortedGames = games
  .map((g) => g.data as GameMeta)
  .sort((a, b) => a.order - b.order);

// Featured games: top 9 most popular
const featuredGames = sortedGames.slice(0, 9);
---

<BaseLayout>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero bg-pattern">
      <div class="container">
        <h1 class="hero-title">
          <span class="gradient-text">{SITE_CONFIG.name}</span>
        </h1>
        <p class="hero-tagline">{SITE_CONFIG.tagline}</p>
        <p class="hero-description">
          Discover your cognitive potential with our free online brain training games.
          Test your typing speed, reaction time, memory, and much more.
          Track your progress and challenge yourself daily.
        </p>
        <div class="hero-actions">
          <a href="/games/" class="game-btn game-btn--primary game-btn--lg">
            Start Playing
          </a>
          <a href="/about/" class="game-btn game-btn--secondary game-btn--lg">
            Learn More
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-value">{sortedGames.length}+</span>
            <span class="hero-stat-label">Games</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-value">Free</span>
            <span class="hero-stat-label">Forever</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-value">No Ads</span>
            <span class="hero-stat-label">During Games</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Games Grid -->
    <section class="games-section container">
      <h2 class="section-title">Choose Your Challenge</h2>
      <p class="section-description">
        Select a game to test and improve your cognitive abilities.
        Each game tracks your scores so you can monitor your progress over time.
      </p>

      <div class="games-grid" id="games-grid">
        {featuredGames.map((game, i) => (
          <div class="game-card-wrapper">
            <GameCard game={game} index={i} />
          </div>
        ))}
      </div>

      <div class="view-all">
        <a href="/games/" class="game-btn game-btn--primary game-btn--lg">View All {sortedGames.length} Games →</a>
      </div>
    </section>

    
    <!-- Features Section -->
    <section class="features-section container">
      <h2 class="section-title">Why Brain Games Hub?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-icon">🧪</span>
          <h3>Scientifically Designed</h3>
          <p>Games based on cognitive science principles to effectively measure and train your brain.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">📊</span>
          <h3>Track Your Progress</h3>
          <p>Your scores are saved locally. Monitor your improvement over time with detailed statistics.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🎯</span>
          <h3>Challenge Yourself</h3>
          <p>Compare your performance against your own best scores. Beat your personal records!</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🌐</span>
          <h3>Play Anywhere</h3>
          <p>All games work in your browser. No downloads, no accounts. Just play on any device.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Homepage Structured Data: CollectionPage + ItemList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: SITE_CONFIG.name,
    description: SITE_CONFIG.description,
    url: SITE_CONFIG.url,
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: featuredGames.length,
      itemListElement: featuredGames.map((game, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'VideoGame',
          name: game.title,
          url: `${SITE_CONFIG.url}/games/${game.slug}/`,
          description: game.description,
          playMode: 'SinglePlayer',
          applicationCategory: 'GameApplication',
          operatingSystem: 'Web',
        },
      })),
    },
  })} />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: var(--space-20) 0 var(--space-16);
    background: var(--gradient-hero);
  }

  .hero-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-4);
  }

  .hero-tagline {
    font-size: var(--text-2xl);
    color: var(--text-secondary);
    margin-bottom: var(--space-6);
    font-family: var(--font-display);
  }

  .hero-description {
    font-size: var(--text-lg);
    max-width: 640px;
    margin: 0 auto var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat-value {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--accent-cyan);
  }

  .hero-stat-label {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Games Section */
  .games-section {
    padding: var(--space-16) 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-4);
  }

  .section-description {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-8);
  }

  .view-all { text-align: center; margin-top: var(--space-8); }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .games-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .games-grid {
      grid-template-columns: 1fr;
    }
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16);
    color: var(--text-muted);
  }

  /* Features */
  .features-section {
    padding: var(--space-16) 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-12);
  }

  .feature-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-align: center;
    transition: all var(--transition-base);
  }

  .feature-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  .feature-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-4);
  }

  .feature-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .feature-card p {
    font-size: var(--text-sm);
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-12) 0 var(--space-8);
    }

    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-tagline {
      font-size: var(--text-xl);
    }
  }
</style>