---
import { SITE_CONFIG } from '../../lib/constants';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import GameCard from '../../components/shared/GameCard.astro';
import { getCollection } from 'astro:content';
import type { GameMeta } from '../../types/game';

const games = await getCollection('games');
const allGames = games
  .map((g) => g.data as GameMeta)
  .sort((a, b) => a.order - b.order);

const pageTitle = `All Games | ${SITE_CONFIG.name}`;
---

<BaseLayout title={pageTitle}>
  <Header />

  <main class="container">
    <section class="games-hero">
      <h1 class="gradient-text">All Games</h1>
      <p class="hero-desc">Browse all {allGames.length} brain training games. Search or filter by category.</p>
    </section>

    <!-- Search + Filter -->
    <div class="games-toolbar">
      <input
        type="text"
        class="games-search"
        id="games-search"
        placeholder="Search games..."
        autocomplete="off"
      />
      <div class="category-filter" id="category-filter">
        <button class="filter-btn active" data-category="all">All</button>
        <button class="filter-btn" data-category="speed">⚡ Speed</button>
        <button class="filter-btn" data-category="memory">🧠 Memory</button>
        <button class="filter-btn" data-category="logic">🧩 Logic</button>
        <button class="filter-btn" data-category="math">🔢 Math</button>
        <button class="filter-btn" data-category="visual">👁️ Visual</button>
        <button class="filter-btn" data-category="word">📝 Word</button>
        <button class="filter-btn" data-category="coordination">🎯 Coord</button>
        <button class="filter-btn" data-category="focus">💡 Focus</button>
        <button class="filter-btn" data-category="knowledge">❓ Knowledge</button>
        <button class="filter-btn" data-category="casual">🎮 Casual</button>
      </div>
    </div>

    <div class="games-grid" id="games-grid">
      {allGames.map((game, i) => (
        <div class="game-card-wrapper" data-category={game.category} data-title={game.shortTitle.toLowerCase()}>
          <GameCard game={game} index={i} />
        </div>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display:none;">No games found. Try a different search or category.</p>
  </main>

  <Footer />
</BaseLayout>

<script>
  const search = document.getElementById('games-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.game-card-wrapper');
  const noResults = document.getElementById('no-results')!;
  let activeCategory = 'all';

  function filter(): void {
    const query = search.value.toLowerCase().trim();
    let visible = 0;

    cards.forEach(card => {
      const cat = card.getAttribute('data-category')!;
      const title = card.getAttribute('data-title')!;
      const catMatch = activeCategory === 'all' || cat === activeCategory;
      const searchMatch = !query || title.includes(query);
      const show = catMatch && searchMatch;
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  search.addEventListener('input', filter);

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.getAttribute('data-category')!;
      filter();
    });
  });
</script>

<style>
  .games-hero { text-align: center; padding: var(--space-12) 0 var(--space-8); }
  .games-hero h1 { font-size: var(--text-4xl); }
  .hero-desc { color: var(--text-muted); font-size: var(--text-lg); margin-top: var(--space-2); }

  .games-toolbar { margin-bottom: var(--space-8); }
  .games-search {
    display: block; width: 100%; max-width: 400px; margin: 0 auto var(--space-4);
    padding: var(--space-3) var(--space-4); background: var(--bg-tertiary);
    border: 2px solid var(--border-medium); border-radius: var(--radius-full);
    color: var(--text-primary); font-size: var(--text-base); outline: none;
    transition: border-color 0.2s;
  }
  .games-search:focus { border-color: var(--accent-cyan); box-shadow: 0 0 12px rgba(0,229,255,0.15); }
  .games-search::placeholder { color: var(--text-muted); }

  .category-filter { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-2); }
  .filter-btn {
    padding: var(--space-1) var(--space-3); background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle); border-radius: var(--radius-full);
    color: var(--text-secondary); font-size: var(--text-xs); font-weight: 500;
    cursor: pointer; transition: all 0.2s; font-family: var(--font-sans);
  }
  .filter-btn:hover { border-color: var(--border-strong); color: var(--text-primary); }
  .filter-btn.active { background: var(--gradient-accent); border-color: transparent; color: #fff; }

  .games-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); }
  @media (max-width: 768px) { .games-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .games-grid { grid-template-columns: 1fr; } }

  .no-results { text-align: center; padding: var(--space-12); color: var(--text-muted); font-size: var(--text-lg); }
</style>