---
import SEOHead from '../components/seo/SEOHead.astro';
import OrganizationJsonLd from '../components/seo/OrganizationJsonLd.astro';
import AnimatedBackground from '../components/effects/AnimatedBackground.astro';
import '../styles/global.css';
import '../styles/motion.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Free online brain training games to test and improve your cognitive abilities.',
  ogImage = '/og-image.png',
  canonicalUrl,
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Preconnect to Google Fonts for faster loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload critical fonts -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@500;600;700;800&display=swap" />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalUrl={canonicalUrl}
      noIndex={noIndex}
    />
    <style is:global>
      /* Inline critical CSS to prevent FOUC */
      body { visibility: hidden; }
      html[data-loaded] body { visibility: visible; }
    </style>
    <!-- AdSense script — disabled until Google AdSense integration -->
    <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXX" crossorigin="anonymous" is:inline></script> -->
  </head>
  <body class="bg-pattern">
    <!-- Skip to content for accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <AnimatedBackground />
    <script is:inline>
      // Prevent FOUC
      document.documentElement.setAttribute('data-loaded', '');
    </script>
    <div id="main-content">
      <slot />
    </div>
    <!-- Site-wide Structured Data -->
    <OrganizationJsonLd />
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -100px;
    left: 8px;
    background: var(--accent-cyan);
    color: #000;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    z-index: 1000;
    transition: top 0.2s;
  }
  .skip-link:focus {
    top: 8px;
  }
</style>