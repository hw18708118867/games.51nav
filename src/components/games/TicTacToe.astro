---
// TicTacToe — vs AI with difficulty
---

<div class="game-container" id="tictactoe-game">
  <div class="ttt-status" id="ttt-status">Your turn (X)</div>
  <div class="ttt-board" id="ttt-board"></div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="ttt-player">0</span><span class="stat-label">You</span></div>
    <div class="stat"><span class="stat-value" id="ttt-draws">0</span><span class="stat-label">Draws</span></div>
    <div class="stat"><span class="stat-value" id="ttt-ai">0</span><span class="stat-label">AI</span></div>
  </div>
  <div class="ttt-actions">
    <div class="ttt-difficulty"><button class="game-btn game-btn--secondary t3-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary t3-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary t3-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="ttt-restart">New Game</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';
  const DIFF: Record<string, string> = { easy: 'easy', medium: 'medium', hard: 'hard' };
  let diff: keyof typeof DIFF = 'easy';
  let board: string[] = Array(9).fill('');
  let player = 0, ai = 0, draws = 0;
  let over = false;

  const boardEl = document.getElementById('ttt-board')!, statusEl = document.getElementById('ttt-status')!;

  function render(): void {
    boardEl.innerHTML = '';
    board.forEach((v, i) => {
      const cell = document.createElement('div');
      cell.className = 'ttt-cell';
      cell.textContent = v;
      if (v) { cell.classList.add(v === 'X' ? 'ttt-x' : 'ttt-o'); cell.classList.add('ttt-pop'); }
      cell.addEventListener('click', () => humanMove(i));
      boardEl.appendChild(cell);
    });
  }

  function checkWin(b: string[], p: string): boolean {
    const wins = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
    return wins.some(w => w.every(i => b[i] === p));
  }

  function humanMove(i: number): void {
    if (over || board[i]) return;
    board[i] = 'X'; render();
    if (checkWin(board, 'X')) { over = true; player++; statusEl.textContent = '🎉 You win!'; updateStats(); saveScore('tictactoe', player); return; }
    if (!board.includes('')) { over = true; draws++; statusEl.textContent = '🤝 Draw!'; updateStats(); return; }
    statusEl.textContent = 'AI thinking...';
    setTimeout(() => { aiMove(); render(); if (checkWin(board, 'O')) { over = true; ai++; statusEl.textContent = '💻 AI wins!'; updateStats(); } else if (!board.includes('')) { over = true; draws++; statusEl.textContent = '🤝 Draw!'; updateStats(); } else { statusEl.textContent = 'Your turn (X)'; } }, 300);
  }

  function aiMove(): void {
    const d = DIFF[diff];
    if (d === 'easy') {
      // Random move
      const avail = board.map((v, i) => v ? -1 : i).filter(i => i >= 0);
      if (avail.length) board[avail[Math.floor(Math.random() * avail.length)]] = 'O';
      return;
    }
    // Medium/Hard: try to win, then block
    for (const p of ['O', 'X']) {
      for (let i = 0; i < 9; i++) {
        if (board[i]) continue;
        board[i] = p;
        if (checkWin(board, p)) { if (p === 'O') return; board[i] = ''; break; }
        board[i] = '';
      }
    }
    // Medium: 50% chance of optimal, else random
    if (d === 'medium' && Math.random() < 0.5) {
      const avail = board.map((v, i) => v ? -1 : i).filter(i => i >= 0);
      if (avail.length) board[avail[Math.floor(Math.random() * avail.length)]] = 'O';
      return;
    }
    // Hard / Medium fallback: take center, corners, edges
    const pref = [4, 0, 2, 6, 8, 1, 3, 5, 7];
    for (const i of pref) { if (!board[i]) { board[i] = 'O'; return; } }
  }

  function updateStats(): void {
    document.getElementById('ttt-player')!.textContent = String(player);
    document.getElementById('ttt-draws')!.textContent = String(draws);
    document.getElementById('ttt-ai')!.textContent = String(ai);
  }

  function init(): void {
    board = Array(9).fill(''); over = false;
    statusEl.textContent = 'Your turn (X)';
    render();
  }

  document.querySelectorAll('.t3-diff-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.t3-diff-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); diff = (b as HTMLElement).dataset.diff as keyof typeof DIFF; init(); }); });
  document.getElementById('ttt-restart')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #tictactoe-game .ttt-status { text-align: center; font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; margin-bottom: var(--space-4); }
  #tictactoe-game .ttt-board { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; max-width: 320px; margin: 0 auto; background: var(--bg-tertiary); border-radius: var(--radius-lg); padding: 10px; }
  #tictactoe-game .ttt-cell { aspect-ratio: 1; background: var(--bg-secondary); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 3rem; font-weight: 700; cursor: pointer; transition: all .15s; }
  #tictactoe-game .ttt-cell:not(.ttt-x):not(.ttt-o):hover { background: var(--bg-hover); transform: scale(1.04); }
  #tictactoe-game .ttt-x { color: var(--accent-cyan); text-shadow: 0 0 12px rgba(0,229,255,.3); }
  #tictactoe-game .ttt-o { color: var(--accent-orange); text-shadow: 0 0 12px rgba(255,145,0,.3); }
  #tictactoe-game .ttt-cell.ttt-pop { animation: t3-pop .3s cubic-bezier(.34,1.56,.64,1); }
  @keyframes t3-pop { 0%{transform:scale(0);opacity:0} 100%{transform:scale(1);opacity:1} }
  #tictactoe-game .ttt-actions { text-align: center; margin-top: var(--space-4); }
  #tictactoe-game .ttt-difficulty { display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap; }
  #tictactoe-game .t3-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #tictactoe-game .t3-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
</style>