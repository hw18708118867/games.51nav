---
// Racing — horizontal obstacle avoidance
---

<div class="game-container" id="racing-game">
  <canvas id="rc-canvas" class="rc-canvas"></canvas>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="rc-score">0</span><span class="stat-label">Score</span></div>
    <div class="stat"><span class="stat-value" id="rc-best">0</span><span class="stat-label">Best</span></div>
    <div class="stat"><span class="stat-value" id="rc-speed">0</span><span class="stat-label">km/h</span></div>
  </div>
  <div class="rc-actions">
    <div class="rc-difficulty"><button class="game-btn game-btn--secondary rc-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary rc-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary rc-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="rc-restart">New Game</button>
  </div>
  <p class="rc-hint">↑↓ or WS to move · P pause · Touch: drag</p>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const DIFF = { easy: { baseSpeed: 2, scoreMul: 1, lives: 3 }, medium: { baseSpeed: 3, scoreMul: 2, lives: 2 }, hard: { baseSpeed: 4, scoreMul: 3, lives: 1 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  const canvas = document.getElementById('rc-canvas') as HTMLCanvasElement, ctx = canvas.getContext('2d')!;
  let W = 700, H = 400;
  const KEYS = new Set<string>();
  let carY = 180, carW = 32, carH = 56, carX = 70;
  let obstacles: number[][] = [], particles: number[][] = [];
  let score = 0, best = parseInt(localStorage.getItem('racing-best') || '0'), lives = 3, speed = 1, maxSpeed = 14;
  let over = false, running = false, paused = false, loopId = 0, tick = 0, readyCount = 3;
  let roadOffset = 0;
  let touchY = 0, touching = false;

  const sEl = document.getElementById('rc-score')!, bEl = document.getElementById('rc-best')!, vEl = document.getElementById('rc-speed')!;

  function resize(): void {
    const r = canvas.parentElement!.getBoundingClientRect();
    W = Math.min(700, r.width - 32); H = Math.min(400, innerHeight * 0.5);
    canvas.width = W; canvas.height = H;
    carY = H / 2 - carH / 2;
  }

  function spawnObstacle(): void {
    const w = 30 + Math.random() * 20, h = 20 + Math.random() * 15;
    obstacles.push([W + 30, Math.random() * (H - 120) + 60, w, h, 0]);
  }

  function pfx(x: number, y: number, color: string, n: number): void {
    for (let i = 0; i < n; i++) { const a = Math.random() * Math.PI * 2, s = 1 + Math.random() * 3; particles.push([x, y, Math.cos(a) * s, Math.sin(a) * s, 8 + Math.random() * 8, color]); }
  }

  function update(): void {
    if (!running || over || paused) return;
    tick++;
    if (readyCount > 0) { if (tick % 50 === 0) readyCount--; return; }

    speed = Math.min(maxSpeed, cfg.baseSpeed + tick * 0.003);
    vEl.textContent = String(Math.floor(speed * 20));

    // Road scroll from right to left (car is driving right)
    roadOffset = (roadOffset - speed * 1.5) % 50;
    if (roadOffset < 0) roadOffset += 50;

    // Car movement
    if (KEYS.has('ArrowUp') || KEYS.has('KeyW')) carY -= 4;
    if (KEYS.has('ArrowDown') || KEYS.has('KeyS')) carY += 4;
    if (touching) carY += (touchY - carY - carH / 2) * 0.2;
    carY = Math.max(50, Math.min(H - carH - 50, carY));

    // Move obstacles
    for (let i = obstacles.length - 1; i >= 0; i--) {
      obstacles[i][0] -= speed;
      obstacles[i][4] += 0.02;
      if (obstacles[i][0] < -60) { obstacles.splice(i, 1); score += cfg.scoreMul; sEl.textContent = String(score); continue; }
      const o = obstacles[i];
      // Tighter collision: shrink both hitboxes by 30%
      const ox = o[0] + o[2] * 0.15, oy = o[1] + o[3] * 0.15, ow = o[2] * 0.7, oh = o[3] * 0.7;
      const cx = carX + carW * 0.15, cy = carY + carH * 0.15, cw = carW * 0.7, ch = carH * 0.7;
      if (cx < ox + ow && cx + cw > ox && cy < oy + oh && cy + ch > oy) {
        pfx(carX + carW / 2, carY + carH / 2, '#FF5252', 15);
        obstacles.splice(i, 1);
        lives--; if (lives <= 0) { endGame(); return; }
        break;
      }
    }

    // Spawn
    const spawnRate = Math.max(15, 70 - tick * 0.02);
    if (tick % Math.floor(spawnRate) === 0) spawnObstacle();
    if (Math.random() < 0.015) spawnObstacle();

    // Particles
    for (let i = particles.length - 1; i >= 0; i--) { particles[i][0] += particles[i][2]; particles[i][1] += particles[i][3]; particles[i][4]--; if (particles[i][4] <= 0) particles.splice(i, 1); }
    if (particles.length > 50) particles.splice(0, particles.length - 50);

    // Exhaust from rear (left side of car)
    if (tick % 3 === 0) { pfx(carX + 5, carY + carH * 0.3, '#FF9100', 1); pfx(carX + 5, carY + carH * 0.7, '#FF9100', 1); }

    if (tick % 10 === 0) { score++; sEl.textContent = String(score); if (score > best) { best = score; localStorage.setItem('racing-best', String(best)); bEl.textContent = String(best); } }
  }

  function endGame(): void {
    over = true; running = false;
    pfx(carX + carW / 2, carY + carH / 2, '#FF5252', 30);
    pfx(carX + carW / 2, carY + carH / 2, '#FFD740', 15);
    saveScore('racing', score);
    setTimeout(() => { (window as any).__gameFeedback?.({ type: 'lose', title: 'Crashed!', score: `${score}`, detail: `${Math.floor(speed * 20)} km/h · ${diff}` }); }, 600);
  }

  function draw(): void {
    ctx.fillStyle = '#1a1a2e'; ctx.fillRect(0, 0, W, H);

    // Road surface
    const roadTop = 50, roadBot = H - 50;
    ctx.fillStyle = '#2a2a3e'; ctx.fillRect(0, roadTop, W, roadBot - roadTop);

    // Road lines
    ctx.fillStyle = '#fff';
    ctx.fillRect(0, roadTop - 2, W, 4);
    ctx.fillRect(0, roadBot - 2, W, 4);

    // Road dashes (scroll right to left → car drives right)
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    for (let x = roadOffset; x < W + 50; x += 50) ctx.fillRect(x, H / 2 - 1, 30, 2);

    // Obstacles — 🚗 facing left (towards player)
    ctx.font = '36px sans-serif'; ctx.textAlign = 'center';
    for (let i = 0; i < obstacles.length; i++) {
      const o = obstacles[i];
      ctx.save();
      ctx.translate(o[0] + o[2] / 2, o[1] + o[3] / 2);
      ctx.fillStyle = 'rgba(0,0,0,0.3)';
      ctx.fillText('🚗', 2, 14);
      ctx.fillText('🚗', 0, 12);
      ctx.restore();
    }

    // Player car — 🏎️ (flipped to face right)
    ctx.save();
    ctx.translate(carX + carW / 2, carY + carH / 2);
    ctx.scale(-1, 1);
    ctx.font = '48px sans-serif'; ctx.textAlign = 'center';
    // Shadow
    ctx.fillStyle = 'rgba(0,0,0,0.3)';
    ctx.fillText('🏎️', 3, 18);
    // Car
    ctx.fillText('🏎️', 0, 15);
    ctx.restore();

    // Particles
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      ctx.fillStyle = p[5]; ctx.globalAlpha = p[4] / 12;
      ctx.fillRect(p[0] - 1, p[1] - 1, 3, 3);
    }
    ctx.globalAlpha = 1;

    // Lives
    ctx.fillStyle = '#FF5252'; ctx.font = '14px sans-serif'; ctx.textAlign = 'left';
    ctx.fillText('❤️'.repeat(Math.max(0, lives)), 10, 24);

    // Countdown
    if (readyCount > 0) {
      ctx.fillStyle = 'rgba(0,0,0,0.4)'; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = '#fff'; ctx.font = 'bold 48px Outfit, sans-serif'; ctx.textAlign = 'center';
      ctx.fillText(String(readyCount), W / 2, H / 2 + 16);
    } else if (readyCount === 0 && tick < 40) {
      ctx.fillStyle = 'rgba(0,0,0,0.3)'; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = '#00E676'; ctx.font = 'bold 36px Outfit, sans-serif'; ctx.textAlign = 'center';
      ctx.fillText('GO!', W / 2, H / 2 + 12);
    }

    if (over) {
      ctx.fillStyle = 'rgba(0,0,0,0.6)'; ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = '#FF5252'; ctx.font = 'bold 36px Outfit, sans-serif'; ctx.textAlign = 'center';
      ctx.fillText('CRASHED!', W / 2, H / 2 - 10);
      ctx.fillStyle = '#fff'; ctx.font = '18px Outfit, sans-serif'; ctx.fillText(`Score: ${score}`, W / 2, H / 2 + 25);
    }
  }

  let lastTime = 0;
  function loop(ts: number): void {
    if (ts - lastTime >= 16) { lastTime = ts; update(); draw(); }
    loopId = requestAnimationFrame(loop);
  }

  function init(): void {
    cancelAnimationFrame(loopId);
    cfg = DIFF[diff]; maxSpeed = 10 + cfg.baseSpeed * 2;
    resize();
    carY = H / 2 - carH / 2; obstacles = []; particles = [];
    score = 0; lives = cfg.lives; speed = cfg.baseSpeed; tick = 0; readyCount = 3;
    over = false; running = true; paused = false;
    sEl.textContent = '0'; bEl.textContent = String(best); vEl.textContent = '0';
    lastTime = performance.now();
    loopId = requestAnimationFrame(loop);
  }

  document.addEventListener('keydown', e => { KEYS.add(e.code); if (e.code === 'KeyP' && !over) paused = !paused; });
  document.addEventListener('keyup', e => { KEYS.delete(e.code); });
  canvas.addEventListener('touchstart', e => { e.preventDefault(); touching = true; touchY = e.touches[0].clientY - canvas.getBoundingClientRect().top; });
  canvas.addEventListener('touchmove', e => { e.preventDefault(); touchY = e.touches[0].clientY - canvas.getBoundingClientRect().top; });
  canvas.addEventListener('touchend', () => { touching = false; });
  window.addEventListener('resize', resize);
  document.querySelectorAll('.rc-diff-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.rc-diff-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); diff = (b as HTMLElement).dataset.diff as keyof typeof DIFF; init(); }); });
  document.getElementById('rc-restart')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #racing-game .rc-canvas { display: block; max-width: 100%; margin: 0 auto; border-radius: var(--radius-lg); border: 2px solid var(--border-medium); background: #1a1a2e; }
  #racing-game .rc-actions { text-align: center; margin-top: var(--space-4); }
  #racing-game .rc-difficulty { display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap; }
  #racing-game .rc-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #racing-game .rc-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
  #racing-game .rc-hint { text-align: center; font-size: var(--text-xs); color: var(--text-muted); margin-top: var(--space-2); }
</style>