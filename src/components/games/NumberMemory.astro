---
// NumberMemory — digit recall with difficulty
---
<div class="game-container" id="number-memory-game">
  <div class="number-display-area">
    <div class="number-show" id="number-show"><span class="number-text" id="number-text">Ready?</span></div>
    <div class="number-feedback" id="number-feedback"></div>
    <div class="number-input-area" id="number-input-area" style="display:none">
      <input type="text" inputmode="numeric" id="number-input" class="number-input" placeholder="Enter number..." autocomplete="off" maxlength="20"/>
      <button class="game-btn game-btn--primary" id="number-submit-btn">Submit</button>
    </div>
  </div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="level-display">1</span><span class="stat-label">Level</span></div>
    <div class="stat"><span class="stat-value" id="digits-display">3</span><span class="stat-label">Digits</span></div>
    <div class="stat"><span class="stat-value" id="streak-display">0</span><span class="stat-label">Streak</span></div>
  </div>
  <div class="number-actions">
    <div class="number-difficulty"><button class="game-btn game-btn--secondary nm-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary nm-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary nm-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="number-restart-btn">Restart</button>
  </div>
</div>
<script>
  import { saveScore } from '../../lib/scoring';
  const DIFF = { easy: { showMs: 1200, startDigits: 3 }, medium: { showMs: 800, startDigits: 4 }, hard: { showMs: 500, startDigits: 5 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  let level = 1, digits = cfg.startDigits, num = '', streak = 0, showing = false, over = false;
  const tEl = document.getElementById('number-text')!, showEl = document.getElementById('number-show')!;
  const fbEl = document.getElementById('number-feedback')!;
  const inArea = document.getElementById('number-input-area')!, inp = document.getElementById('number-input') as HTMLInputElement;
  const lEl = document.getElementById('level-display')!, dEl = document.getElementById('digits-display')!, sEl = document.getElementById('streak-display')!;
  function gen(d:number):string{let s='';for(let i=0;i<d;i++)s+=Math.floor(Math.random()*10);return s}
  function update():void{lEl.textContent=String(level);dEl.textContent=String(digits);sEl.textContent=String(streak)}
  function show():void{if(over)return;showing=true;num=gen(digits);tEl.textContent=num;tEl.classList.remove('nm-pop');void tEl.offsetWidth;tEl.classList.add('nm-pop');showEl.style.display='flex';inArea.style.display='none';inp.value='';fbEl.textContent='';setTimeout(()=>{showEl.style.display='none';inArea.style.display='flex';inp.focus();showing=false},cfg.showMs*digits)}
  function chk():void{const a=inp.value.trim();if(a===num){streak++;level++;digits=Math.min(20,cfg.startDigits+Math.floor((level-1)/2));update();inArea.style.display='none';fbEl.textContent='';setTimeout(()=>show(),500)}else{over=true;saveScore('number-memory',level);fbEl.innerHTML=`Answer: <strong>${num}</strong>`;fbEl.className='number-feedback nm-err';tEl.textContent='Game Over!';showEl.style.display='flex';inArea.style.display='none';(window as any).__gameFeedback?.({type:'lose',title:'Wrong Number!',score:`Level ${level}`,detail:`${digits} digits · ${diff}`})}}
  function init():void{cfg=DIFF[diff];level=1;digits=cfg.startDigits;streak=0;over=false;fbEl.textContent='';update();show()}
  document.getElementById('number-submit-btn')!.addEventListener('click',chk);inp.addEventListener('keydown',e=>{if(e.key==='Enter')chk()});
  document.querySelectorAll('.nm-diff-btn').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.nm-diff-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');diff=(b as HTMLElement).dataset.diff as keyof typeof DIFF;init()})});
  document.getElementById('number-restart-btn')!.addEventListener('click',init);init();
</script>
<style is:global>
  #number-memory-game .number-display-area{text-align:center;min-height:200px;display:flex;flex-direction:column;align-items:center;justify-content:center}
  #number-memory-game .number-show{display:flex;align-items:center;justify-content:center;min-height:120px}
  #number-memory-game .number-text{font-family:var(--font-mono);font-size:4rem;font-weight:700;color:var(--accent-cyan);letter-spacing:.1em;text-shadow:0 0 30px rgba(0,229,255,.3)}
  #number-memory-game .number-text.nm-pop{animation:nm-pop .3s cubic-bezier(.34,1.56,.64,1)}
  @keyframes nm-pop{0%{transform:scale(.5);opacity:0}100%{transform:scale(1);opacity:1}}
  #number-memory-game .number-feedback{font-size:var(--text-lg);font-weight:600;min-height:28px;margin-bottom:var(--space-3)}
  #number-memory-game .number-feedback.nm-err{color:var(--accent-red);animation:nm-fb-pop .3s ease}
  @keyframes nm-fb-pop{0%{transform:scale(.5)}100%{transform:scale(1)}}
  #number-memory-game .number-input-area{display:flex;flex-direction:column;align-items:center;gap:var(--space-4);animation:fadeIn .3s}
  #number-memory-game .number-input{width:100%;max-width:400px;background:var(--bg-tertiary);border:2px solid var(--border-medium);border-radius:var(--radius-md);padding:var(--space-4);font-family:var(--font-mono);font-size:2rem;color:var(--text-primary);text-align:center;letter-spacing:.1em;outline:none}
  #number-memory-game .number-input:focus{border-color:var(--accent-cyan);box-shadow:0 0 12px rgba(0,229,255,.15)}
  #number-memory-game .number-actions{text-align:center;margin-top:var(--space-6)}
  #number-memory-game .number-difficulty{display:flex;gap:var(--space-2);justify-content:center;margin-bottom:var(--space-4)}
  #number-memory-game .nm-diff-btn{font-size:var(--text-sm);padding:var(--space-2) var(--space-4)}
  #number-memory-game .nm-diff-btn.active{background:var(--gradient-accent);color:#fff;border-color:transparent}
  @media(max-width:768px){#number-memory-game .number-text{font-size:2.5rem}#number-memory-game .number-input{font-size:1.5rem}}
</style>