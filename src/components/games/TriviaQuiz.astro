---
// TriviaQuiz — knowledge quiz with difficulty
---

<div class="game-container" id="trivia-game">
  <div class="tq-question" id="tq-question">Loading...</div>
  <div class="tq-feedback" id="tq-feedback"></div>
  <div class="tq-options" id="tq-options"></div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="tq-score">0</span><span class="stat-label">Score</span></div>
    <div class="stat"><span class="stat-value" id="tq-round">1/10</span><span class="stat-label">Question</span></div>
    <div class="stat"><span class="stat-value" id="tq-streak">0</span><span class="stat-label">Streak</span></div>
  </div>
  <div class="tq-actions">
    <div class="tq-difficulty"><button class="game-btn game-btn--secondary tq-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary tq-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary tq-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="tq-restart">New Quiz</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const QUESTIONS = [
    { q: 'What is the capital of France?', opts: ['London','Paris','Berlin','Madrid'], a: 1 },
    { q: 'How many continents are there?', opts: ['5','6','7','8'], a: 2 },
    { q: 'What planet is closest to the Sun?', opts: ['Venus','Earth','Mars','Mercury'], a: 3 },
    { q: 'What is the largest ocean?', opts: ['Atlantic','Indian','Pacific','Arctic'], a: 2 },
    { q: 'Who painted the Mona Lisa?', opts: ['Van Gogh','Picasso','Da Vinci','Rembrandt'], a: 2 },
    { q: 'What is H2O?', opts: ['Oxygen','Hydrogen','Water','Salt'], a: 2 },
    { q: 'How many bones in the human body?', opts: ['186','206','226','256'], a: 1 },
    { q: 'What language has the most native speakers?', opts: ['English','Spanish','Mandarin','Hindi'], a: 2 },
    { q: 'What year did WWII end?', opts: ['1943','1944','1945','1946'], a: 2 },
    { q: 'What is the speed of light?', opts: ['300,000 km/s','150,000 km/s','500,000 km/s','1,000,000 km/s'], a: 0 },
    { q: 'What is the largest mammal?', opts: ['Elephant','Blue Whale','Giraffe','Hippo'], a: 1 },
    { q: 'What element has symbol Au?', opts: ['Silver','Aluminum','Gold','Argon'], a: 2 },
    { q: 'How many sides does a hexagon have?', opts: ['5','6','7','8'], a: 1 },
    { q: 'What is the main ingredient in guacamole?', opts: ['Tomato','Onion','Avocado','Lime'], a: 2 },
    { q: 'What country is the Eiffel Tower in?', opts: ['Italy','Spain','Germany','France'], a: 3 },
    { q: 'What is the hardest natural substance?', opts: ['Iron','Diamond','Quartz','Titanium'], a: 1 },
    { q: 'How many strings on a standard guitar?', opts: ['4','5','6','7'], a: 2 },
    { q: 'What is the largest desert?', opts: ['Sahara','Gobi','Antarctic','Arabian'], a: 2 },
    { q: 'Who wrote Romeo and Juliet?', opts: ['Dickens','Shakespeare','Austen','Hemingway'], a: 1 },
    { q: 'What is the chemical symbol for iron?', opts: ['Ir','Fe','In','Io'], a: 1 },
    { q: 'What is the longest river?', opts: ['Amazon','Nile','Yangtze','Mississippi'], a: 1 },
    { q: 'How many colors in a rainbow?', opts: ['5','6','7','8'], a: 2 },
    { q: 'What is the smallest country?', opts: ['Monaco','Vatican City','San Marino','Malta'], a: 1 },
    { q: 'What gas do plants absorb?', opts: ['Oxygen','Nitrogen','CO2','Helium'], a: 2 },
    { q: 'What is the boiling point of water?', opts: ['90°C','100°C','110°C','120°C'], a: 1 },
    { q: 'Who discovered gravity?', opts: ['Einstein','Newton','Galileo','Darwin'], a: 1 },
    { q: 'What is the largest continent?', opts: ['Africa','North America','Asia','Europe'], a: 2 },
    { q: 'How many players on a soccer team?', opts: ['9','10','11','12'], a: 2 },
    { q: 'What is the tallest animal?', opts: ['Elephant','Giraffe','Camel','Horse'], a: 1 },
    { q: 'What is the currency of Japan?', opts: ['Won','Yuan','Yen','Dollar'], a: 2 },
    { q: 'What planet is known as the Red Planet?', opts: ['Venus','Jupiter','Mars','Saturn'], a: 2 },
    { q: 'What is the largest organ?', opts: ['Heart','Liver','Skin','Brain'], a: 2 },
    { q: 'How many minutes in an hour?', opts: ['30','45','60','90'], a: 2 },
    { q: 'What is the main gas in air?', opts: ['Oxygen','Nitrogen','CO2','Helium'], a: 1 },
    { q: 'Who painted Starry Night?', opts: ['Picasso','Van Gogh','Monet','Da Vinci'], a: 1 },
    { q: 'What is the capital of Japan?', opts: ['Seoul','Beijing','Tokyo','Bangkok'], a: 2 },
    { q: 'How many days in a leap year?', opts: ['364','365','366','367'], a: 2 },
    { q: 'What is the fastest land animal?', opts: ['Lion','Cheetah','Horse','Gazelle'], a: 1 },
    { q: 'What is the symbol for sodium?', opts: ['So','Sd','Na','No'], a: 2 },
    { q: 'What is the largest bird?', opts: ['Eagle','Albatross','Ostrich','Penguin'], a: 2 },
  ];

  const DIFF = { easy: { total: 10, pts: 10 }, medium: { total: 15, pts: 15 }, hard: { total: 20, pts: 20 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  let used: number[] = [], round = 1, score = 0, streak = 0, answerIdx = 0;
  let over = false;

  const qEl = document.getElementById('tq-question')!, fbEl = document.getElementById('tq-feedback')!;
  const optsEl = document.getElementById('tq-options')!;
  const sEl = document.getElementById('tq-score')!, rEl = document.getElementById('tq-round')!, stEl = document.getElementById('tq-streak')!;

  function render(): void {
    if (round > cfg.total) { finish(); return; }
    const avail = QUESTIONS.map((_, i) => i).filter(i => !used.includes(i));
    if (!avail.length) { used = []; render(); return; }
    const idx = avail[Math.floor(Math.random() * avail.length)];
    used.push(idx);
    const q = QUESTIONS[idx];
    answerIdx = q.a;

    qEl.textContent = q.q;
    qEl.classList.remove('tq-pop'); void qEl.offsetWidth; qEl.classList.add('tq-pop');
    fbEl.textContent = '';

    optsEl.innerHTML = '';
    q.opts.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'tq-opt-btn';
      btn.setAttribute('type', 'button');
      btn.textContent = opt;
      btn.addEventListener('click', () => answer(i, btn));
      optsEl.appendChild(btn);
    });
  }

  function answer(i: number, el: HTMLElement): void {
    if (over) return;
    if (i === answerIdx) { streak++; score += cfg.pts + streak * 3; el.classList.add('correct'); fbEl.textContent = '✓ Correct!'; fbEl.className = 'tq-feedback tq-ok'; }
    else { streak = 0; el.classList.add('wrong'); optsEl.children[answerIdx].classList.add('correct'); fbEl.textContent = '✗ Wrong!'; fbEl.className = 'tq-feedback tq-err'; }
    setTimeout(() => { fbEl.className = 'tq-feedback'; }, 500);
    round++; update(); setTimeout(render, 600);
  }

  function update(): void { sEl.textContent = String(score); rEl.textContent = `${Math.min(round, cfg.total)}/${cfg.total}`; stEl.textContent = String(streak); }

  function finish(): void {
    over = true; saveScore('trivia-quiz', score);
    qEl.textContent = 'Quiz Complete!'; optsEl.innerHTML = '';
    const acc = Math.round((streak ? streak : 0) / cfg.total * 100);
    (window as any).__gameFeedback?.({ type: score >= cfg.total * cfg.pts ? 'win' : 'lose', title: score >= cfg.total * cfg.pts ? 'Genius!' : 'Quiz Complete!', score: `${score} pts`, detail: `${diff} · ${cfg.total} questions` });
  }

  function init(): void { cfg = DIFF[diff]; used = []; round = 1; score = 0; streak = 0; over = false; rEl.textContent = `1/${cfg.total}`; update(); render(); }

  document.querySelectorAll('.tq-diff-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.tq-diff-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); diff = (b as HTMLElement).dataset.diff as keyof typeof DIFF; init(); }); });
  document.getElementById('tq-restart')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #trivia-game .tq-question { text-align: center; font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; margin-bottom: var(--space-2); min-height: 60px; display: flex; align-items: center; justify-content: center; }
  #trivia-game .tq-question.tq-pop { animation: tq-pop .4s cubic-bezier(.34,1.56,.64,1); }
  @keyframes tq-pop { 0%{transform:scale(.8);opacity:0} 100%{transform:scale(1);opacity:1} }
  #trivia-game .tq-feedback { text-align: center; font-size: var(--text-lg); font-weight: 600; min-height: 28px; margin-bottom: var(--space-4); }
  #trivia-game .tq-feedback.tq-ok { color: var(--accent-green); animation: tq-fb-pop .3s ease; }
  #trivia-game .tq-feedback.tq-err { color: var(--accent-red); animation: tq-fb-pop .3s ease; }
  @keyframes tq-fb-pop { 0%{transform:scale(.5)} 100%{transform:scale(1)} }
  #trivia-game .tq-options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-width: 500px; margin: 0 auto; }
  #trivia-game .tq-opt-btn { padding: var(--space-4); border: 2px solid var(--border-medium); border-radius: var(--radius-md); background: var(--bg-tertiary); color: var(--text-primary); font-size: var(--text-base); font-weight: 500; cursor: pointer; transition: all .2s; text-align: left; }
  #trivia-game .tq-opt-btn:hover { border-color: var(--accent-cyan); background: var(--bg-hover); transform: translateX(4px); }
  #trivia-game .tq-opt-btn.correct { border-color: var(--accent-green); background: rgba(0,230,118,.12); color: var(--accent-green); animation: tq-ok .3s ease; }
  @keyframes tq-ok { 0%{transform:scale(1)} 50%{transform:scale(1.03)} 100%{transform:scale(1)} }
  #trivia-game .tq-opt-btn.wrong { border-color: var(--accent-red); background: rgba(255,82,82,.12); color: var(--accent-red); animation: tq-err .3s ease; }
  @keyframes tq-err { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-4px)} 75%{transform:translateX(4px)} }
  #trivia-game .tq-actions { text-align: center; margin-top: var(--space-4); }
  #trivia-game .tq-difficulty { display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap; }
  #trivia-game .tq-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #trivia-game .tq-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
</style>