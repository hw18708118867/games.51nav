---
// MemoryTest — card matching game with difficulty levels
---

<div class="game-container" id="memory-test-game">
  <div class="memory-grid" id="memory-grid"></div>

  <div class="game-stats" id="memory-stats">
    <div class="stat">
      <span class="stat-value" id="moves-display">0</span>
      <span class="stat-label">Moves</span>
    </div>
    <div class="stat">
      <span class="stat-value" id="pairs-display">0/8</span>
      <span class="stat-label">Found</span>
    </div>
    <div class="stat">
      <span class="stat-value" id="memory-time-display">0s</span>
      <span class="stat-label">Time</span>
    </div>
  </div>

  <div class="memory-actions">
    <div class="memory-difficulty">
      <button class="game-btn game-btn--secondary mem-diff-btn active" data-diff="beginner">Beginner</button>
      <button class="game-btn game-btn--secondary mem-diff-btn" data-diff="intermediate">Intermediate</button>
      <button class="game-btn game-btn--secondary mem-diff-btn" data-diff="advanced">Advanced</button>
    </div>
    <button class="game-btn game-btn--primary" id="memory-restart-btn">New Game</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const EMOJIS = ['🧠','⚡','🎯','🌟','🔥','💎','🎮','🚀','🦊','🐸','🦋','🌙','🍀','🎵','👾'];

  const DIFFICULTY = {
    beginner:  { pairs: 8,  matchSize: 2, cols: 4, label: 'Beginner' },
    intermediate: { pairs: 12, matchSize: 2, cols: 6, label: 'Intermediate' },
    advanced:  { pairs: 10, matchSize: 3, cols: 6, label: 'Advanced' },
  } as const;

  type DiffKey = keyof typeof DIFFICULTY;
  let diff: DiffKey = 'beginner';
  let cfg = DIFFICULTY[diff];

  let cards: { emoji: string; pairId: number }[] = [];
  let flipped: HTMLElement[] = [];
  let moves = 0;
  let found = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let startTime = 0;
  let locked = false;

  const grid = document.getElementById('memory-grid')!;
  const movesEl = document.getElementById('moves-display')!;
  const pairsEl = document.getElementById('pairs-display')!;
  const timeEl = document.getElementById('memory-time-display')!;

  function shuffle<T>(a: T[]): T[] {
    const arr = [...a];
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function buildCards(): void {
    const icons = shuffle(EMOJIS).slice(0, cfg.pairs);
    cards = shuffle(icons.flatMap((e, i) =>
      Array.from({ length: cfg.matchSize }, () => ({ emoji: e, pairId: i }))
    ));
  }

  function render(): void {
    grid.style.gridTemplateColumns = `repeat(${cfg.cols}, 1fr)`;
    grid.innerHTML = '';
    cards.forEach((c, i) => {
      const card = document.createElement('div');
      card.className = 'mem-card';
      card.dataset.pair = String(c.pairId);
      card.dataset.state = 'hidden';
      card.innerHTML = `
        <span class="mem-face mem-front">?</span>
        <span class="mem-face mem-back">${c.emoji}</span>
      `;
      card.addEventListener('click', () => click(card));
      grid.appendChild(card);
    });
  }

  function click(card: HTMLElement): void {
    if (locked) return;
    if (card.dataset.state !== 'hidden') return;
    if (flipped.includes(card)) return;

    if (!startTime) {
      startTime = Date.now();
      timer = setInterval(() => { timeEl.textContent = `${Math.floor((Date.now() - startTime) / 1000)}s`; }, 200);
    }

    card.dataset.state = 'revealed';
    flipped.push(card);

    if (flipped.length < cfg.matchSize) return;

    // Enough cards flipped — check match
    moves++;
    movesEl.textContent = String(moves);
    locked = true;

    const allSame = flipped.every(c => c.dataset.pair === flipped[0].dataset.pair);

    if (allSame) {
      setTimeout(() => {
        flipped.forEach(c => { c.dataset.state = 'done'; });
        found++;
        pairsEl.textContent = `${found}/${cfg.pairs}`;
        flipped = [];
        locked = false;
        if (found === cfg.pairs) finish();
      }, 350);
    } else {
      setTimeout(() => {
        flipped.forEach(c => { c.dataset.state = 'hidden'; });
        flipped = [];
        locked = false;
      }, 800);
    }
  }

  function finish(): void {
    if (timer) clearInterval(timer);
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const score = Math.max(100, 2000 - moves * 15 - elapsed * 3);
    saveScore('memory-test', score);
    (window as any).__gameFeedback?.({
      type: 'win',
      title: 'All Found!',
      score: `${moves} moves`,
      detail: `${cfg.label} · ${elapsed}s · Score: ${score}`,
    });
  }

  function init(): void {
    if (timer) { clearInterval(timer); timer = null; }
    cfg = DIFFICULTY[diff];
    moves = 0; found = 0; flipped = []; locked = false; startTime = 0;
    movesEl.textContent = '0';
    pairsEl.textContent = `0/${cfg.pairs}`;
    timeEl.textContent = '0s';
    buildCards();
    render();
  }

  // Difficulty buttons
  document.querySelectorAll('.mem-diff-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mem-diff-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      diff = (btn as HTMLElement).dataset.diff as DiffKey;
      init();
    });
  });

  document.getElementById('memory-restart-btn')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #memory-test-game .memory-grid {
    display: grid;
    gap: 10px;
    max-width: 620px;
    margin: 0 auto;
  }

  #memory-test-game .mem-card {
    aspect-ratio: 1;
    position: relative;
    cursor: pointer;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border: 2px solid var(--border-medium);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s, background 0.2s;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }

  #memory-test-game .mem-face {
    position: absolute;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #memory-test-game .mem-front {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--text-muted);
    opacity: 1;
    transform: scale(1);
  }

  #memory-test-game .mem-card[data-state="revealed"] .mem-front,
  #memory-test-game .mem-card[data-state="done"] .mem-front {
    opacity: 0;
    transform: scale(0.3);
  }

  #memory-test-game .mem-back {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    opacity: 0;
    transform: scale(0.3);
  }

  #memory-test-game .mem-card[data-state="revealed"] .mem-back,
  #memory-test-game .mem-card[data-state="done"] .mem-back {
    opacity: 1;
    transform: scale(1);
  }

  /* Hover */
  #memory-test-game .mem-card[data-state="hidden"]:hover {
    border-color: var(--accent-purple);
    box-shadow: 0 0 14px rgba(124, 77, 255, 0.25);
    transform: translateY(-2px);
  }
  #memory-test-game .mem-card[data-state="hidden"]:active {
    transform: scale(0.95);
  }

  /* Revealed */
  #memory-test-game .mem-card[data-state="revealed"] {
    border-color: var(--accent-cyan);
    background: var(--bg-tertiary);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.18);
  }

  /* Done */
  #memory-test-game .mem-card[data-state="done"] {
    border-color: var(--accent-green);
    background: rgba(0, 230, 118, 0.08);
    box-shadow: 0 0 14px rgba(0, 230, 118, 0.2);
    cursor: default;
    animation: mem-pop 0.4s ease;
  }

  @keyframes mem-pop {
    0% { transform: scale(1); }
    40% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  /* Difficulty */
  #memory-test-game .memory-actions {
    text-align: center;
    margin-top: var(--space-6);
  }

  #memory-test-game .memory-difficulty {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  #memory-test-game .mem-diff-btn {
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
  }

  #memory-test-game .mem-diff-btn.active {
    background: var(--gradient-accent);
    color: #fff;
    border-color: transparent;
  }

  @media (max-width: 520px) {
    #memory-test-game .memory-grid { gap: 6px; }
  }
</style>