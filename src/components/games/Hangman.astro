---
// Hangman — word guessing with difficulty
---

<div class="game-container" id="hangman-game">
  <div class="hm-figure">
    <svg viewBox="0 0 120 160" width="120" height="160">
      <line x1="20" y1="150" x2="100" y2="150" stroke="var(--text-muted)" stroke-width="3" stroke-linecap="round"/>
      <line x1="40" y1="150" x2="40" y2="10" stroke="var(--text-muted)" stroke-width="3" stroke-linecap="round"/>
      <line x1="40" y1="10" x2="80" y2="10" stroke="var(--text-muted)" stroke-width="3" stroke-linecap="round"/>
      <line x1="80" y1="10" x2="80" y2="30" stroke="var(--text-muted)" stroke-width="3" stroke-linecap="round"/>
      <g id="hm-body" opacity="0">
        <circle cx="80" cy="42" r="14" fill="none" stroke="var(--accent-red)" stroke-width="3"/>
        <line x1="80" y1="56" x2="80" y2="100" stroke="var(--accent-red)" stroke-width="3" stroke-linecap="round"/>
        <line x1="80" y1="66" x2="60" y2="80" stroke="var(--accent-red)" stroke-width="3" stroke-linecap="round"/>
        <line x1="80" y1="66" x2="100" y2="80" stroke="var(--accent-red)" stroke-width="3" stroke-linecap="round"/>
        <line x1="80" y1="100" x2="65" y2="130" stroke="var(--accent-red)" stroke-width="3" stroke-linecap="round"/>
        <line x1="80" y1="100" x2="95" y2="130" stroke="var(--accent-red)" stroke-width="3" stroke-linecap="round"/>
      </g>
    </svg>
  </div>
  <div class="hm-word" id="hm-word"></div>
  <div class="hm-hint" id="hm-hint"></div>
  <div class="hm-keyboard" id="hm-keyboard"></div>
  <div class="hm-actions">
    <div class="hm-difficulty"><button class="game-btn game-btn--secondary hm-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary hm-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary hm-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="hm-restart">New Word</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const WORDS: Record<string, [string, string][]> = {
    easy: [
      ['CAT','Pet'],['DOG','Pet'],['SUN','Star'],['CAR','Vehicle'],['HAT','Clothing'],
      ['BED','Furniture'],['FISH','Animal'],['BOOK','Reading'],['TREE','Plant'],['MOON','Night sky'],
      ['BIRD','Animal'],['CAKE','Dessert'],['DOOR','Entrance'],['FIRE','Element'],['GOLD','Metal'],
      ['KING','Royalty'],['LION','Animal'],['MILK','Drink'],['NOSE','Body part'],['ROSE','Flower'],
    ],
    medium: [
      ['PYTHON','Programming'],['GUITAR','Instrument'],['JUNGLE','Forest'],['CASTLE','Building'],
      ['ROCKET','Space'],['BRIDGE','Structure'],['PLANET','Space'],['TIGER','Animal'],['CAMERA','Device'],
      ['ISLAND','Land'],['DRAGON','Mythical'],['WINTER','Season'],['GARDEN','Plants'],['OCEAN','Water'],
      ['KNIGHT','Warrior'],['MIRROR','Reflects'],['FOREST','Nature'],['CANDLE','Light'],['DESERT','Dry land'],
    ],
    hard: [
      ['MYSTERY','Unknown'],['JOURNEY','Trip'],['PHOENIX','Fire bird'],['PYRAMID','Egypt'],
      ['VOLCANO','Eruption'],['GLACIER','Ice'],['BLIZZARD','Snow storm'],['TWILIGHT','Dusk'],
      ['MYSTICAL','Magical'],['LABYRINTH','Maze'],['SYMPHONY','Music'],['PARADOX','Contradiction'],
      ['ECLIPSE','Shadow'],['HORIZON','Skyline'],['MAVERICK','Rebel'],['ZEPPELIN','Airship'],
    ],
  };

  const DIFF = { easy: { max: 6, pts: 10 }, medium: { max: 5, pts: 15 }, hard: { max: 4, pts: 20 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  let word = '', hint = '';
  let guessed: Set<string> = new Set();
  let wrong = 0, maxWrong = 6;

  const wordEl = document.getElementById('hm-word')!, hintEl = document.getElementById('hm-hint')!;
  const keyboardEl = document.getElementById('hm-keyboard')!, bodyEl = document.getElementById('hm-body')!;

  function render(): void {
    wordEl.innerHTML = word.split('').map(ch =>
      `<span class="hm-letter ${guessed.has(ch) ? '' : 'hm-hidden'}">${guessed.has(ch) ? ch : '_'}</span>`
    ).join('');
    bodyEl.style.opacity = String(wrong / maxWrong);
    keyboardEl.innerHTML = '';
    'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(ch => {
      const btn = document.createElement('button');
      btn.className = 'hm-btn'; btn.setAttribute('type', 'button'); btn.textContent = ch;
      if (guessed.has(ch)) btn.classList.add(word.includes(ch) ? 'hm-correct' : 'hm-wrong');
      btn.addEventListener('click', () => guess(ch));
      keyboardEl.appendChild(btn);
    });
  }

  function guess(ch: string): void {
    if (guessed.has(ch) || wrong >= maxWrong) return;
    guessed.add(ch);
    if (!word.includes(ch)) wrong++;
    render();

    if (word.split('').every(c => guessed.has(c))) {
      saveScore('hangman', maxWrong - wrong);
      setTimeout(() => { (window as any).__gameFeedback?.({ type: 'win', title: 'You Saved Him!', score: word, detail: `${wrong}/${maxWrong} wrong · ${diff}` }); }, 500);
    } else if (wrong >= maxWrong) {
      wordEl.innerHTML = word.split('').map(ch => `<span class="hm-letter hm-reveal">${ch}</span>`).join('');
      saveScore('hangman', 0);
      setTimeout(() => { (window as any).__gameFeedback?.({ type: 'lose', title: 'Game Over', score: word, detail: `Hint: ${hint}` }); }, 800);
    }
  }

  function init(): void {
    cfg = DIFF[diff]; maxWrong = cfg.max;
    const pool = WORDS[diff];
    const pick = pool[Math.floor(Math.random() * pool.length)];
    word = pick[0]; hint = pick[1];
    guessed = new Set(); wrong = 0;
    hintEl.textContent = `Hint: ${hint}`;
    render();
  }

  document.addEventListener('keydown', e => { const ch = e.key.toUpperCase(); if (/^[A-Z]$/.test(ch)) guess(ch); });
  document.querySelectorAll('.hm-diff-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.hm-diff-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); diff = (b as HTMLElement).dataset.diff as keyof typeof DIFF; init(); }); });
  document.getElementById('hm-restart')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #hangman-game .hm-figure { text-align: center; margin-bottom: var(--space-4); }
  #hangman-game .hm-word { display: flex; gap: 8px; justify-content: center; margin-bottom: var(--space-3); flex-wrap: wrap; }
  #hangman-game .hm-letter { font-family: var(--font-mono); font-size: 2rem; font-weight: 700; width: 40px; text-align: center; border-bottom: 3px solid var(--accent-cyan); color: var(--text-primary); padding-bottom: 4px; transition: all .2s; }
  #hangman-game .hm-letter.hm-hidden { color: transparent; }
  #hangman-game .hm-letter.hm-reveal { color: var(--accent-red); border-color: var(--accent-red); animation: hm-reveal .3s ease; }
  @keyframes hm-reveal { 0%{transform:scale(1.3)} 100%{transform:scale(1)} }
  #hangman-game .hm-hint { text-align: center; font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-4); }
  #hangman-game .hm-keyboard { display: flex; flex-wrap: wrap; gap: 5px; justify-content: center; max-width: 420px; margin: 0 auto; }
  #hangman-game .hm-btn { width: 38px; height: 40px; border: 1px solid var(--border-medium); border-radius: var(--radius-sm); background: var(--bg-tertiary); color: var(--text-primary); font-family: var(--font-sans); font-size: .85rem; font-weight: 600; cursor: pointer; transition: all .15s; padding: 0; }
  #hangman-game .hm-btn:hover { background: var(--bg-hover); border-color: var(--accent-cyan); }
  #hangman-game .hm-btn.hm-correct { background: var(--accent-green); color: #fff; border-color: var(--accent-green); cursor: default; }
  #hangman-game .hm-btn.hm-wrong { background: var(--bg-tertiary); color: var(--text-muted); border-color: var(--border-subtle); cursor: default; opacity: .5; }
  #hangman-game .hm-actions { text-align: center; margin-top: var(--space-4); }
  #hangman-game .hm-difficulty { display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap; }
  #hangman-game .hm-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #hangman-game .hm-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
</style>