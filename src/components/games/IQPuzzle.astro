---
// IQPuzzle — pattern recognition with difficulty levels
---

<div class="game-container" id="iq-puzzle-game">
  <div class="iq-display">
    <div class="iq-question" id="iq-question">
      <div class="iq-matrix" id="iq-matrix"></div>
    </div>
    <div class="iq-options" id="iq-options"></div>
    <div class="iq-feedback" id="iq-feedback" style="display:none;"></div>
  </div>

  <div class="game-stats">
    <div class="stat">
      <span class="stat-value" id="iq-score-display">0</span>
      <span class="stat-label">Score</span>
    </div>
    <div class="stat">
      <span class="stat-value" id="iq-round-display">1/10</span>
      <span class="stat-label">Question</span>
    </div>
    <div class="stat">
      <span class="stat-value" id="iq-correct-display">0</span>
      <span class="stat-label">Correct</span>
    </div>
  </div>

  <div class="iq-actions">
    <div class="iq-difficulty">
      <button class="game-btn game-btn--secondary iq-diff-btn active" data-diff="easy">Easy</button>
      <button class="game-btn game-btn--secondary iq-diff-btn" data-diff="medium">Medium</button>
      <button class="game-btn game-btn--secondary iq-diff-btn" data-diff="hard">Hard</button>
    </div>
    <button class="game-btn game-btn--primary" id="iq-restart-btn">New Game</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const DIFF = { easy: { total: 10, gens: 6, pts: 10 }, medium: { total: 15, gens: 9, pts: 12 }, hard: { total: 20, gens: 12, pts: 15 } };
  let difficulty: keyof typeof DIFF = 'easy';
  let cfg = DIFF[difficulty];
  let round = 1, score = 0, correct = 0, answerIdx = 0;
  let finished = false;

  const matrixEl = document.getElementById('iq-matrix')!;
  const optionsEl = document.getElementById('iq-options')!;
  const feedbackEl = document.getElementById('iq-feedback')!;
  const scoreEl = document.getElementById('iq-score-display')!;
  const roundEl = document.getElementById('iq-round-display')!;
  const correctEl = document.getElementById('iq-correct-display')!;

  function pick<T>(a: T[]): T { return a[Math.floor(Math.random() * a.length)]; }
  function rng(min: number, max: number): number { return Math.floor(Math.random() * (max - min + 1)) + min; }

  function shuffle<T>(a: T[]): T[] {
    const arr = [...a];
    for (let i = arr.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [arr[i], arr[j]] = [arr[j], arr[i]]; }
    return arr;
  }

  function uniqueOptions(correct: string, pool: string[]): string[] {
    const opts = [correct];
    for (const c of shuffle(pool)) { if (opts.length >= 6) break; if (!opts.includes(c)) opts.push(c); }
    return shuffle(opts);
  }

  const DISTRACTORS = ['●','■','▲','★','◆','⬢','⬡','◇','○','☆','⬟','⬠','🟡','🟣','🟠','⚪','⚫','🔴','🔵','🟢'];

  type Puzzle = { matrix: string[][]; options: string[]; answer: number }; // answer = index in shuffled options

  const generators: (() => Puzzle)[] = [
    // 1. Rotation
    () => {
      const sets = [['▲','▶','▼','◀'],['◆','◇','◆','◇'],['⬟','⬢','⬟','⬢']];
      const s = pick(sets); const o = rng(0, 3);
      const correct = s[(o+3)%4];
      const opts = uniqueOptions(correct, DISTRACTORS);
      return { matrix: [[s[o%4],s[(o+1)%4],s[(o+2)%4]],[s[(o+1)%4],s[(o+2)%4],s[(o+3)%4]],[s[(o+2)%4],s[(o+3)%4],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 2. Color shift
    () => {
      const sets = [['🔴','🔵','🟢'],['🟡','🟣','🟠'],['🟤','⚪','⚫']];
      const c = pick(sets);
      const correct = c[1];
      const opts = uniqueOptions(correct, DISTRACTORS);
      return { matrix: [[c[0],c[1],c[2]],[c[1],c[2],c[0]],[c[2],c[0],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 3. Number sequence
    () => {
      const s = rng(1,5), step = rng(1,3);
      const a=s, b=a+step, c=b+step;
      const correct = `${c}`;
      const opts = uniqueOptions(correct, [`${c+step}`,`${c-step}`,`${a}`,`${b}`,`${c*2}`,`${rng(1,20)}`]);
      return { matrix: [[`${a}`,`${a}`,`${a}`],[`${b}`,`${b}`,`${b}`],[`${c}`,`${c}`,'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 4. Arithmetic
    () => {
      const x = rng(1,6), y = rng(1,6);
      const op = pick(['+','×']);
      const correct = `${op}`;
      const r = op === '+' ? x+y : x*y;
      const opts = uniqueOptions(correct, [`${x}`,`${y}`,`${r}`,`+`,`×`,`${rng(1,9)}`]);
      return { matrix: [[`${x}`,`${op}`,`${y}`],[`${y}`,`${op}`,`${x}`],[`${r}`,`?`,`${r}`]], options: opts, answer: opts.indexOf(correct) };
    },
    // 5. Mirror
    () => {
      const s = pick(['⬢','◆','★','●','■','▲']);
      const opts = uniqueOptions(s, DISTRACTORS);
      return { matrix: [[s,'⬡',s],[s,'⬡','?'],[s,'⬡',s]], options: opts, answer: opts.indexOf(s) };
    },
    // 6. Fill progression
    () => {
      const fills = pick([['□','◐','■'],['○','◑','●'],['☆','⯪','★']]);
      const correct = fills[2];
      const opts = uniqueOptions(correct, DISTRACTORS);
      return { matrix: [[fills[0],fills[0],fills[0]],[fills[0],fills[1],fills[1]],[fills[0],fills[1],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 7. Shape count
    () => {
      const s = pick(['●','■','▲','★']);
      const n = [rng(1,3), rng(1,3), rng(1,3)];
      const correct = s.repeat(n[2]);
      const opts = uniqueOptions(correct, [s.repeat(n[0]),s.repeat(n[1]),s+s,s.repeat(rng(1,3)),'●','■']);
      return { matrix: [[s.repeat(n[0]),s.repeat(n[1]),'?'],[s.repeat(n[1]),s.repeat(n[2]),s.repeat(n[0])],[s.repeat(n[2]),s.repeat(n[0]),s.repeat(n[1])]], options: opts, answer: opts.indexOf(correct) };
    },
    // 8. Alternating
    () => {
      const a = pick(['⬢','◆','●']), b = pick(['⬡','◇','○']);
      const opts = uniqueOptions(a, DISTRACTORS);
      return { matrix: [[a,b,a],[b,a,b],[a,b,'?']], options: opts, answer: opts.indexOf(a) };
    },
    // 9. Size
    () => {
      const s = pick(['●','■','▲','⬢']);
      const sizes = ['·'+s, s, s+s];
      const correct = sizes[2];
      const opts = uniqueOptions(correct, [sizes[0],sizes[1],s+s+s,'·'+s,pick(['●','■','▲'])]);
      return { matrix: [[sizes[0],sizes[0],sizes[0]],[sizes[0],sizes[1],sizes[1]],[sizes[0],sizes[1],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 10. Letter
    () => {
      const letters = 'ABCDEFGH'.split('');
      const i = rng(0, 4);
      const correct = letters[i+4];
      const opts = uniqueOptions(correct, [`${letters[i+3]}`,`${letters[i+2]}`,`${letters[i+1]}`,`X`,`Y`,`Z`]);
      return { matrix: [[letters[i],letters[i+1],letters[i+2]],[letters[i+1],letters[i+2],letters[i+3]],[letters[i+2],letters[i+3],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 11. Opposite
    () => {
      const pairs = [['⬢','⬡'],['◆','◇'],['▲','▼'],['▶','◀']];
      const p = pick(pairs);
      const correct = p[0];
      const opts = uniqueOptions(correct, DISTRACTORS);
      return { matrix: [[p[0],p[1],p[0]],[p[1],p[0],p[1]],[p[0],p[1],'?']], options: opts, answer: opts.indexOf(correct) };
    },
    // 12. Corner
    () => {
      const a = rng(1,5), b = rng(1,5), c = rng(1,5);
      const correct = `${a+b}`;
      const opts = uniqueOptions(correct, [`${b+c}`,`${a+c}`,`${a+b+c}`,`${a}`,`${b}`,`${c}`]);
      return { matrix: [[`${a}`,`${b}`,`?`],[`${c}`,`${a+b+c}`,`${a+b}`],[`${a+c}`,`${b+c}`,`${a+b+c}`]], options: opts, answer: opts.indexOf(correct) };
    },
  ];

  function getGens(): (() => Puzzle)[] { return generators.slice(0, cfg.gens); }

  function render(): void {
    if (round > cfg.total) { finish(); return; }
    const gen = pick(getGens());
    const puzzle = gen();
    answerIdx = puzzle.answer;

    feedbackEl.style.display = 'none';
    matrixEl.innerHTML = '';
    matrixEl.classList.add('iq-matrix-pop');
    setTimeout(() => matrixEl.classList.remove('iq-matrix-pop'), 400);

    puzzle.matrix.flat().forEach(cell => {
      const el = document.createElement('div');
      el.className = 'iq-cell';
      el.textContent = cell;
      if (cell === '?') el.classList.add('iq-missing');
      matrixEl.appendChild(el);
    });

    optionsEl.innerHTML = '';
    puzzle.options.forEach((opt, i) => {
      const el = document.createElement('button');
      el.className = 'iq-option';
      el.setAttribute('type', 'button');
      el.textContent = opt;
      el.addEventListener('click', () => answer(i, el));
      optionsEl.appendChild(el);
    });
  }

  function answer(i: number, el: HTMLElement): void {
    if (finished) return;

    if (i === answerIdx) {
      correct++; score += cfg.pts;
      el.classList.add('correct');
      feedbackEl.style.display = 'none';
    } else {
      el.classList.add('wrong');
      // Highlight correct answer
      Array.from(optionsEl.children).forEach(c => c.classList.remove('correct'));
      const correctEl = optionsEl.children[answerIdx] as HTMLElement;
      if (correctEl) correctEl.classList.add('correct');
      // Show what the correct answer was
      feedbackEl.innerHTML = `Correct answer: <strong>${correctEl?.textContent || ''}</strong>`;
      feedbackEl.style.display = 'block';
      feedbackEl.classList.add('iq-fb-pop');
      setTimeout(() => feedbackEl.classList.remove('iq-fb-pop'), 400);
    }

    round++;
    update();
    setTimeout(render, 800);
  }

  function update(): void {
    scoreEl.textContent = String(score);
    roundEl.textContent = `${Math.min(round, cfg.total)}/${cfg.total}`;
    correctEl.textContent = String(correct);
  }

  function finish(): void {
    finished = true;
    saveScore('iq-puzzle', score);
    matrixEl.innerHTML = '<div class="iq-complete">🧠 Complete!</div>';
    optionsEl.innerHTML = '';
    feedbackEl.style.display = 'none';
    const acc = Math.round((correct / cfg.total) * 100);
    (window as any).__gameFeedback?.({
      type: acc >= 70 ? 'win' : 'lose',
      title: acc >= 70 ? 'Sharp Mind!' : 'Good Effort!',
      score: `${score} pts`,
      detail: `${correct}/${cfg.total} · ${acc}% · ${difficulty}`,
    });
  }

  function init(): void {
    cfg = DIFF[difficulty];
    round = 1; score = 0; correct = 0; finished = false;
    roundEl.textContent = `1/${cfg.total}`;
    update(); render();
  }

  document.querySelectorAll('.iq-diff-btn').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.iq-diff-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      difficulty = (b as HTMLElement).dataset.diff as keyof typeof DIFF;
      init();
    });
  });
  document.getElementById('iq-restart-btn')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #iq-puzzle-game .iq-display { text-align: center; }
  #iq-puzzle-game .iq-matrix {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
    max-width: 300px; margin: 0 auto;
  }
  #iq-puzzle-game .iq-matrix.iq-matrix-pop {
    animation: iq-mx-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes iq-mx-pop {
    0% { transform: scale(0.8); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  #iq-puzzle-game .iq-cell {
    aspect-ratio: 1;
    background: var(--bg-tertiary); border: 2px solid var(--border-medium);
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem;
  }
  #iq-puzzle-game .iq-cell.iq-missing {
    border-color: var(--accent-orange); border-style: dashed;
    background: rgba(255,145,0,0.06);
    animation: iq-missing-glow 1.5s ease-in-out infinite;
  }
  @keyframes iq-missing-glow {
    0%, 100% { box-shadow: 0 0 0 rgba(255,145,0,0); }
    50% { box-shadow: 0 0 20px rgba(255,145,0,0.3); }
  }

  #iq-puzzle-game .iq-options {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
    max-width: 420px; margin: var(--space-6) auto 0;
  }
  #iq-puzzle-game .iq-option {
    aspect-ratio: 1;
    background: var(--bg-tertiary); border: 2px solid var(--border-medium);
    border-radius: var(--radius-lg);
    display: flex; align-items: center; justify-content: center;
    font-size: 2.2rem; cursor: pointer;
    transition: all 0.2s; padding: 0; outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  #iq-puzzle-game .iq-option:hover {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 20px rgba(0,229,255,0.25);
    transform: translateY(-3px) scale(1.05);
  }
  #iq-puzzle-game .iq-option.correct {
    border-color: var(--accent-green) !important;
    background: rgba(0,230,118,0.12) !important;
    animation: iq-ok 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 0 24px rgba(0,230,118,0.4) !important;
  }
  @keyframes iq-ok {
    0% { transform: scale(1); }
    40% { transform: scale(1.2); }
    70% { transform: scale(0.9); }
    100% { transform: scale(1); }
  }
  #iq-puzzle-game .iq-option.wrong {
    border-color: var(--accent-red) !important;
    background: rgba(255,82,82,0.12) !important;
    animation: iq-err 0.5s ease;
    box-shadow: 0 0 20px rgba(255,82,82,0.3) !important;
  }
  @keyframes iq-err {
    0%, 100% { transform: translateX(0); }
    15% { transform: translateX(-8px); }
    30% { transform: translateX(8px); }
    45% { transform: translateX(-6px); }
    60% { transform: translateX(6px); }
    75% { transform: translateX(-3px); }
    90% { transform: translateX(3px); }
  }

  #iq-puzzle-game .iq-feedback {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--accent-orange);
    font-weight: 600;
  }
  #iq-puzzle-game .iq-feedback.iq-fb-pop {
    animation: iq-fb-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes iq-fb-in {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  #iq-puzzle-game .iq-feedback strong {
    color: var(--accent-green);
    font-size: 1.3em;
  }

  #iq-puzzle-game .iq-complete {
    grid-column: 1/-1; padding: var(--space-8);
    font-family: var(--font-display); font-size: var(--text-2xl); color: var(--accent-green);
  }
  #iq-puzzle-game .iq-actions { text-align: center; margin-top: var(--space-6); }
  #iq-puzzle-game .iq-difficulty {
    display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap;
  }
  #iq-puzzle-game .iq-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #iq-puzzle-game .iq-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
</style>