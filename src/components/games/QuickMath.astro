---
// QuickMath — true/false with difficulty
---
<div class="game-container" id="quick-math-game">
  <div class="qm-display">
    <div class="qm-equation" id="qm-equation">12 + 8 = 20</div>
    <div class="qm-feedback" id="qm-feedback"></div>
    <div class="qm-prompt">Is this equation correct?</div>
  </div>
  <div class="qm-buttons"><button class="game-btn game-btn--primary qm-true-btn" id="qm-true-btn">✓ TRUE</button><button class="game-btn game-btn--secondary qm-false-btn" id="qm-false-btn">✗ FALSE</button></div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="qm-score-display">0</span><span class="stat-label">Score</span></div>
    <div class="stat"><span class="stat-value" id="qm-streak-display">0</span><span class="stat-label">Streak</span></div>
    <div class="stat"><span class="stat-value" id="qm-time-display">30s</span><span class="stat-label">Time</span></div>
  </div>
  <div class="qm-actions">
    <div class="qm-difficulty"><button class="game-btn game-btn--secondary qm-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary qm-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary qm-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="qm-restart-btn">New Game</button>
  </div>
</div>
<script>
  import { saveScore } from '../../lib/scoring';
  const DIFF = { easy: { time: 30, ops: ['+','-'], pts: 10 }, medium: { time: 30, ops: ['+','-','×'], pts: 15 }, hard: { time: 20, ops: ['+','-','×','÷'], pts: 20 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  let score = 0, streak = 0, timeLeft = cfg.time, isCorrect = true, running = false, timer: ReturnType<typeof setInterval>|null = null;
  const eqEl = document.getElementById('qm-equation')!, fbEl = document.getElementById('qm-feedback')!;
  const sEl = document.getElementById('qm-score-display')!, stEl = document.getElementById('qm-streak-display')!, tEl = document.getElementById('qm-time-display')!;
  function gen(): void { const op=cfg.ops[Math.floor(Math.random()*cfg.ops.length)],d=1+Math.floor(score/30);let a:number,b:number,real:number;switch(op){case'+':a=Math.floor(Math.random()*30*d)+5;b=Math.floor(Math.random()*30*d)+5;real=a+b;break;case'-':a=Math.floor(Math.random()*50*d)+20;b=Math.floor(Math.random()*(a-1))+1;real=a-b;break;case'×':a=Math.floor(Math.random()*12*d)+2;b=Math.floor(Math.random()*12)+2;real=a*b;break;case'÷':b=Math.floor(Math.random()*12)+2;real=Math.floor(Math.random()*12)+1;a=real*b;break;}isCorrect=Math.random()<.5;let disp=isCorrect?real:real+(Math.random()<.5?1:-1)*(1+Math.floor(Math.random()*3));if(!isCorrect&&disp===real)disp=real+1;eqEl.textContent=`${a} ${op} ${b} = ${Math.max(0,disp)}` }
  function answer(u:boolean):void{if(!running)return;if(u===isCorrect){streak++;score+=cfg.pts+streak*2;fbEl.textContent='✓';fbEl.className='qm-feedback qm-ok'}else{streak=0;fbEl.textContent='✗';fbEl.className='qm-feedback qm-err';eqEl.classList.add('qm-shake');setTimeout(()=>eqEl.classList.remove('qm-shake'),300)}setTimeout(()=>{fbEl.className='qm-feedback'},400);update();gen()}
  function update():void{sEl.textContent=String(score);stEl.textContent=String(streak);tEl.textContent=`${timeLeft}s`}
  function start():void{score=0;streak=0;timeLeft=cfg.time;running=true;update();gen();timer=setInterval(()=>{timeLeft--;tEl.textContent=`${timeLeft}s`;if(timeLeft<=0)end()},1000)}
  function end():void{running=false;if(timer){clearInterval(timer);timer=null}saveScore('quick-math',score);eqEl.textContent=`Done! Score: ${score}`;(window as any).__gameFeedback?.({type:score>=100?'win':'lose',title:score>=100?'Quick Thinker!':'Time\'s Up!',score:`${score} pts`,detail:`${diff} · Streak: ${streak}`})}
  function init():void{if(timer){clearInterval(timer);timer=null}cfg=DIFF[diff];fbEl.textContent='';start()}
  document.getElementById('qm-true-btn')!.addEventListener('click',()=>answer(true));document.getElementById('qm-false-btn')!.addEventListener('click',()=>answer(false));
  document.addEventListener('keydown',e=>{if(e.key==='ArrowLeft')answer(true);if(e.key==='ArrowRight')answer(false)});
  document.querySelectorAll('.qm-diff-btn').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.qm-diff-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');diff=(b as HTMLElement).dataset.diff as keyof typeof DIFF;init()})});
  document.getElementById('qm-restart-btn')!.addEventListener('click',init);init();
</script>
<style is:global>
  #quick-math-game .qm-display{text-align:center}
  #quick-math-game .qm-equation{font-family:var(--font-mono);font-size:2.5rem;font-weight:700;margin-bottom:var(--space-2);transition:color .2s}
  #quick-math-game .qm-equation.qm-shake{animation:qm-shake .3s ease}
  @keyframes qm-shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
  #quick-math-game .qm-feedback{font-size:var(--text-lg);font-weight:600;min-height:28px}
  #quick-math-game .qm-feedback.qm-ok{color:var(--accent-green);animation:qm-pop .2s ease}
  #quick-math-game .qm-feedback.qm-err{color:var(--accent-red);animation:qm-pop .2s ease}
  @keyframes qm-pop{0%{transform:scale(.5);opacity:0}100%{transform:scale(1);opacity:1}}
  #quick-math-game .qm-prompt{font-size:var(--text-sm);color:var(--text-muted);margin-bottom:var(--space-4)}
  #quick-math-game .qm-buttons{display:flex;gap:var(--space-4);justify-content:center}
  #quick-math-game .qm-buttons .game-btn{min-width:160px;font-size:var(--text-lg);padding:var(--space-4) var(--space-8)}
  #quick-math-game .qm-actions{text-align:center;margin-top:var(--space-6)}
  #quick-math-game .qm-difficulty{display:flex;gap:var(--space-2);justify-content:center;margin-bottom:var(--space-4)}
  #quick-math-game .qm-diff-btn{font-size:var(--text-sm);padding:var(--space-2) var(--space-4)}
  #quick-math-game .qm-diff-btn.active{background:var(--gradient-accent);color:#fff;border-color:transparent}
  @media(max-width:768px){#quick-math-game .qm-equation{font-size:1.8rem}#quick-math-game .qm-buttons .game-btn{min-width:130px}}
</style>