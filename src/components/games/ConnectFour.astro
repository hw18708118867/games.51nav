---
// ConnectFour — vs AI with difficulty
---

<div class="game-container" id="connect4-game">
  <div class="c4-status" id="c4-status">🔴 Your turn</div>
  <div class="c4-board" id="c4-board"></div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="c4-wins">0</span><span class="stat-label">Wins</span></div>
    <div class="stat"><span class="stat-value" id="c4-losses">0</span><span class="stat-label">Losses</span></div>
    <div class="stat"><span class="stat-value" id="c4-draws">0</span><span class="stat-label">Draws</span></div>
  </div>
  <div class="c4-actions">
    <div class="c4-difficulty"><button class="game-btn game-btn--secondary c4-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary c4-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary c4-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="c4-restart">New Game</button>
  </div>
</div>

<script>
  import { saveScore } from '../../lib/scoring';

  const ROWS = 6, COLS = 7;
  let board: number[][] = []; // 0=empty, 1=player(red), 2=AI(yellow)
  let over = false, playerTurn = true;
  let wins = 0, losses = 0, draws = 0;
  let diff: keyof typeof DIFF = 'easy';

  const DIFF = { easy: 'random', medium: 'medium', hard: 'hard' };
  const boardEl = document.getElementById('c4-board')!, statusEl = document.getElementById('c4-status')!;
  const wEl = document.getElementById('c4-wins')!, lEl = document.getElementById('c4-losses')!, dEl = document.getElementById('c4-draws')!;

  function render(): void {
    boardEl.innerHTML = '';
    for (let r = 0; r < ROWS; r++) {
      for (let c = 0; c < COLS; c++) {
        const cell = document.createElement('div');
        cell.className = 'c4-cell';
        cell.addEventListener('click', () => drop(c));
        if (board[r][c]) {
          const piece = document.createElement('div');
          piece.className = `c4-piece c4-p${board[r][c]}`;
          cell.appendChild(piece);
        }
        boardEl.appendChild(cell);
      }
    }
  }

  function drop(col: number): void {
    if (over || !playerTurn) return;
    if (!placePiece(col, 1)) return;
    render();
    if (checkWin(1)) { endGame('win'); return; }
    if (isDraw()) { endGame('draw'); return; }
    playerTurn = false; statusEl.textContent = '🟡 AI thinking...';
    setTimeout(() => aiMove(), 400);
  }

  function placePiece(col: number, player: number): boolean {
    for (let r = ROWS - 1; r >= 0; r--) {
      if (!board[r][col]) { board[r][col] = player; return true; }
    }
    return false;
  }

  function aiMove(): void {
    if (over) return;
    const col = getAiMove();
    placePiece(col, 2);
    render();
    if (checkWin(2)) { endGame('lose'); return; }
    if (isDraw()) { endGame('draw'); return; }
    playerTurn = true; statusEl.textContent = '🔴 Your turn';
  }

  function getAiMove(): number {
    const d = DIFF[diff];
    // Try to win
    if (d !== 'easy') {
      for (let c = 0; c < COLS; c++) { if (canPlace(c)) { placePiece(c, 2); const w = checkWin(2); removePiece(c); if (w) return c; } }
      // Block player win
      for (let c = 0; c < COLS; c++) { if (canPlace(c)) { placePiece(c, 1); const w = checkWin(1); removePiece(c); if (w) return c; } }
    }
    // Hard: prefer center
    if (d === 'hard') {
      const pref = [3, 2, 4, 1, 5, 0, 6];
      for (const c of pref) { if (canPlace(c)) return c; }
    }
    // Random
    const avail: number[] = [];
    for (let c = 0; c < COLS; c++) if (canPlace(c)) avail.push(c);
    return avail[Math.floor(Math.random() * avail.length)];
  }

  function canPlace(col: number): boolean { return !board[0][col]; }
  function removePiece(col: number): void { for (let r = 0; r < ROWS; r++) { if (board[r][col]) { board[r][col] = 0; return; } } }

  function checkWin(p: number): boolean {
    const dirs = [[0,1],[1,0],[1,1],[1,-1]];
    for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
      if (board[r][c] !== p) continue;
      for (const [dr, dc] of dirs) {
        let count = 1;
        for (let i = 1; i < 4; i++) { const nr = r+dr*i, nc = c+dc*i; if (nr>=0&&nr<ROWS&&nc>=0&&nc<COLS&&board[nr][nc]===p) count++; else break; }
        for (let i = 1; i < 4; i++) { const nr = r-dr*i, nc = c-dc*i; if (nr>=0&&nr<ROWS&&nc>=0&&nc<COLS&&board[nr][nc]===p) count++; else break; }
        if (count >= 4) return true;
      }
    }
    return false;
  }

  function isDraw(): boolean { return board[0].every(c => c !== 0); }

  function endGame(result: 'win'|'lose'|'draw'): void {
    over = true;
    if (result === 'win') { wins++; statusEl.textContent = '🔴 You win! 🎉'; saveScore('connect4', 1); }
    else if (result === 'lose') { losses++; statusEl.textContent = '🟡 AI wins!'; }
    else { draws++; statusEl.textContent = '🤝 Draw!'; }
    wEl.textContent = String(wins); lEl.textContent = String(losses); dEl.textContent = String(draws);
    (window as any).__gameFeedback?.({ type: result === 'win' ? 'win' : 'lose', title: result === 'win' ? 'You Win!' : result === 'lose' ? 'AI Wins!' : 'Draw!', score: result, detail: `${diff}` });
  }

  function init(): void {
    board = Array.from({length: ROWS}, () => Array(COLS).fill(0));
    over = false; playerTurn = true;
    statusEl.textContent = '🔴 Your turn';
    render();
  }

  document.querySelectorAll('.c4-diff-btn').forEach(b => { b.addEventListener('click', () => { document.querySelectorAll('.c4-diff-btn').forEach(x => x.classList.remove('active')); b.classList.add('active'); diff = (b as HTMLElement).dataset.diff as keyof typeof DIFF; init(); }); });
  document.getElementById('c4-restart')!.addEventListener('click', init);
  init();
</script>

<style is:global>
  #connect4-game .c4-status { text-align: center; font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; margin-bottom: var(--space-4); }
  #connect4-game .c4-board { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; max-width: 420px; margin: 0 auto; background: #1565C0; border-radius: var(--radius-lg); padding: 10px; }
  #connect4-game .c4-cell { aspect-ratio: 1; background: #0D47A1; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background .15s; }
  #connect4-game .c4-cell:hover { background: #1976D2; transform: scale(1.05); }
  #connect4-game .c4-piece { width: 80%; height: 80%; border-radius: 50%; animation: c4-drop .35s cubic-bezier(.34,1.56,.64,1); }
  @keyframes c4-drop { 0%{transform:translateY(-50px);opacity:0} 60%{transform:translateY(0);opacity:1} 80%{transform:translateY(-5px)} 100%{transform:translateY(0)} }
  #connect4-game .c4-p1 { background: radial-gradient(circle at 35% 35%, #FF8A80, #FF5252); box-shadow: inset 0 -3px 6px rgba(0,0,0,.3); }
  #connect4-game .c4-p2 { background: radial-gradient(circle at 35% 35%, #FFE57F, #FFD740); box-shadow: inset 0 -3px 6px rgba(0,0,0,.3); }
  #connect4-game .c4-actions { text-align: center; margin-top: var(--space-4); }
  #connect4-game .c4-difficulty { display: flex; gap: var(--space-2); justify-content: center; margin-bottom: var(--space-4); flex-wrap: wrap; }
  #connect4-game .c4-diff-btn { font-size: var(--text-sm); padding: var(--space-2) var(--space-4); }
  #connect4-game .c4-diff-btn.active { background: var(--gradient-accent); color: #fff; border-color: transparent; }
</style>