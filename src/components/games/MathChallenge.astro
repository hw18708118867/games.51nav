---
// MathChallenge — arithmetic with difficulty
---
<div class="game-container" id="math-challenge-game">
  <div class="math-display">
    <div class="math-problem" id="math-problem">12 + 34 = ?</div>
    <div class="math-feedback" id="math-feedback"></div>
    <div class="math-input-area">
      <input type="text" inputmode="numeric" id="math-input" class="math-input" placeholder="?" autocomplete="off" />
      <button class="game-btn game-btn--primary" id="math-submit-btn">Submit</button>
    </div>
  </div>
  <div class="game-stats">
    <div class="stat"><span class="stat-value" id="math-score-display">0</span><span class="stat-label">Score</span></div>
    <div class="stat"><span class="stat-value" id="math-streak-display">0</span><span class="stat-label">Streak</span></div>
    <div class="stat"><span class="stat-value" id="math-time-display">30s</span><span class="stat-label">Time</span></div>
  </div>
  <div class="math-actions">
    <div class="math-difficulty"><button class="game-btn game-btn--secondary mc-diff-btn active" data-diff="easy">Easy</button><button class="game-btn game-btn--secondary mc-diff-btn" data-diff="medium">Medium</button><button class="game-btn game-btn--secondary mc-diff-btn" data-diff="hard">Hard</button></div>
    <button class="game-btn game-btn--primary" id="math-restart-btn">New Game</button>
  </div>
</div>
<script>
  import { saveScore } from '../../lib/scoring';
  const DIFF = { easy: { time: 30, ops: ['+','-'], pts: 10 }, medium: { time: 30, ops: ['+','-','×'], pts: 15 }, hard: { time: 20, ops: ['+','-','×','÷'], pts: 20 } };
  let diff: keyof typeof DIFF = 'easy', cfg = DIFF[diff];
  let score = 0, streak = 0, timeLeft = cfg.time, answer = 0, running = false, timer: ReturnType<typeof setInterval>|null = null;
  const pEl = document.getElementById('math-problem')!, fbEl = document.getElementById('math-feedback')!;
  const inp = document.getElementById('math-input') as HTMLInputElement;
  const sEl = document.getElementById('math-score-display')!, stEl = document.getElementById('math-streak-display')!, tEl = document.getElementById('math-time-display')!;
  function gen(): void { const op = cfg.ops[Math.floor(Math.random()*cfg.ops.length)], d = 1+Math.floor(score/30); let a:number,b:number; switch(op){case'+':a=Math.floor(Math.random()*30*d)+5;b=Math.floor(Math.random()*30*d)+5;answer=a+b;break;case'-':a=Math.floor(Math.random()*50*d)+20;b=Math.floor(Math.random()*(a-1))+1;answer=a-b;break;case'×':a=Math.floor(Math.random()*12*d)+2;b=Math.floor(Math.random()*12)+2;answer=a*b;break;case'÷':b=Math.floor(Math.random()*12)+2;answer=Math.floor(Math.random()*12)+1;a=answer*b;break;} pEl.textContent=`${a} ${op} ${b} = ?`; }
  function chk(): void { if(!running)return; const v=parseInt(inp.value,10); if(isNaN(v)||inp.value.trim()==='')return; if(v===answer){streak++;score+=cfg.pts+streak*2;fbEl.textContent='✓';fbEl.className='math-feedback mc-ok'}else{streak=0;fbEl.textContent=`✗ ${answer}`;fbEl.className='math-feedback mc-err';pEl.classList.add('mc-shake');setTimeout(()=>pEl.classList.remove('mc-shake'),300)} setTimeout(()=>{fbEl.className='math-feedback'},500); inp.value='';update();gen();inp.focus(); }
  function update(): void { sEl.textContent=String(score);stEl.textContent=String(streak);tEl.textContent=`${timeLeft}s`; }
  function start(): void { score=0;streak=0;timeLeft=cfg.time;running=true;inp.disabled=false;update();gen();inp.focus();timer=setInterval(()=>{timeLeft--;tEl.textContent=`${timeLeft}s`;if(timeLeft<=0)end()},1000); }
  function end(): void { running=false;if(timer){clearInterval(timer);timer=null}inp.disabled=true;saveScore('math-challenge',score);pEl.textContent=`Done! Score: ${score}`;fbEl.textContent='';(window as any).__gameFeedback?.({type:score>=100?'win':'lose',title:score>=100?'Math Whiz!':'Time\'s Up!',score:`${score} pts`,detail:`${diff} · Streak: ${streak}`}); }
  function init(): void { if(timer){clearInterval(timer);timer=null}cfg=DIFF[diff];fbEl.textContent='';start(); }
  inp.addEventListener('keydown',e=>{if(e.key==='Enter')chk()});document.getElementById('math-submit-btn')!.addEventListener('click',chk);
  document.querySelectorAll('.mc-diff-btn').forEach(b=>{b.addEventListener('click',()=>{document.querySelectorAll('.mc-diff-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');diff=(b as HTMLElement).dataset.diff as keyof typeof DIFF;init()})});
  document.getElementById('math-restart-btn')!.addEventListener('click',init);init();
</script>
<style is:global>
  #math-challenge-game .math-display{text-align:center}
  #math-challenge-game .math-problem{font-family:var(--font-mono);font-size:3rem;font-weight:700;margin-bottom:var(--space-2);transition:color .2s}
  #math-challenge-game .math-problem.mc-shake{animation:mc-shake .3s ease}
  @keyframes mc-shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
  #math-challenge-game .math-feedback{font-size:var(--text-lg);font-weight:600;min-height:28px;margin-bottom:var(--space-4)}
  #math-challenge-game .math-feedback.mc-ok{color:var(--accent-green);animation:mc-pop .2s ease}
  #math-challenge-game .math-feedback.mc-err{color:var(--accent-red);animation:mc-pop .2s ease}
  @keyframes mc-pop{0%{transform:scale(.5);opacity:0}100%{transform:scale(1);opacity:1}}
  #math-challenge-game .math-input-area{display:flex;gap:var(--space-3);justify-content:center;align-items:center}
  #math-challenge-game .math-input{width:160px;background:var(--bg-tertiary);border:2px solid var(--border-medium);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);font-family:var(--font-mono);font-size:1.5rem;color:var(--text-primary);text-align:center;outline:none}
  #math-challenge-game .math-input:focus{border-color:var(--accent-cyan);box-shadow:0 0 12px rgba(0,229,255,.15)}
  #math-challenge-game .math-actions{text-align:center;margin-top:var(--space-6)}
  #math-challenge-game .math-difficulty{display:flex;gap:var(--space-2);justify-content:center;margin-bottom:var(--space-4)}
  #math-challenge-game .mc-diff-btn{font-size:var(--text-sm);padding:var(--space-2) var(--space-4)}
  #math-challenge-game .mc-diff-btn.active{background:var(--gradient-accent);color:#fff;border-color:transparent}
  @media(max-width:768px){#math-challenge-game .math-problem{font-size:2rem}}
</style>