---
// AnimatedBackground — floating particles with parallax
// Slow ambient particles that make the site feel alive
---

<div class="animated-bg" aria-hidden="true">
  <div class="particle particle--1"></div>
  <div class="particle particle--2"></div>
  <div class="particle particle--3"></div>
  <div class="particle particle--4"></div>
  <div class="particle particle--5"></div>
  <div class="particle particle--6"></div>
  <div class="particle particle--7"></div>
  <div class="particle particle--8"></div>
  <div class="particle-ring ring--1"></div>
  <div class="particle-ring ring--2"></div>
</div>

<style is:global>
  .animated-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    opacity: 0;
    animation: float-particle var(--float-dur, 8s) ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
    will-change: transform, opacity;
  }

  .particle--1 {
    --float-dur: 8s; --float-delay: 0s;
    width: 4px; height: 4px;
    background: #00E5FF;
    top: 15%; left: 10%;
  }
  .particle--2 {
    --float-dur: 10s; --float-delay: 2s;
    width: 3px; height: 3px;
    background: #7C4DFF;
    top: 25%; right: 15%;
  }
  .particle--3 {
    --float-dur: 9s; --float-delay: 4s;
    width: 5px; height: 5px;
    background: #448AFF;
    top: 60%; left: 20%;
  }
  .particle--4 {
    --float-dur: 11s; --float-delay: 1s;
    width: 3px; height: 3px;
    background: #00E5FF;
    top: 70%; right: 25%;
  }
  .particle--5 {
    --float-dur: 7s; --float-delay: 3s;
    width: 2px; height: 2px;
    background: #7C4DFF;
    top: 40%; left: 50%;
  }
  .particle--6 {
    --float-dur: 12s; --float-delay: 5s;
    width: 4px; height: 4px;
    background: #00E5FF;
    top: 80%; left: 70%;
  }
  .particle--7 {
    --float-dur: 9.5s; --float-delay: 6s;
    width: 3px; height: 3px;
    background: #448AFF;
    top: 10%; right: 40%;
  }
  .particle--8 {
    --float-dur: 8.5s; --float-delay: 7s;
    width: 2px; height: 2px;
    background: #7C4DFF;
    top: 50%; left: 85%;
  }

  .particle-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid;
    opacity: 0;
    animation: float-ring var(--ring-dur, 12s) ease-in-out infinite;
    animation-delay: var(--ring-delay, 0s);
  }

  .ring--1 {
    --ring-dur: 12s; --ring-delay: 0s;
    width: 60px; height: 60px;
    border-color: rgba(0, 229, 255, 0.15);
    top: 20%; left: 30%;
  }
  .ring--2 {
    --ring-dur: 14s; --ring-delay: 6s;
    width: 40px; height: 40px;
    border-color: rgba(124, 77, 255, 0.12);
    top: 60%; right: 20%;
  }

  @keyframes float-particle {
    0% { transform: translate(0, 0) scale(0); opacity: 0; }
    20% { transform: translate(10px, -20px) scale(1); opacity: 0.6; }
    50% { transform: translate(-8px, -40px) scale(0.8); opacity: 0.3; }
    80% { transform: translate(5px, -15px) scale(1); opacity: 0.5; }
    100% { transform: translate(0, 0) scale(0); opacity: 0; }
  }

  @keyframes float-ring {
    0% { transform: translate(0, 0) rotate(0deg) scale(0.8); opacity: 0; }
    25% { transform: translate(15px, -25px) rotate(90deg) scale(1); opacity: 0.3; }
    50% { transform: translate(-10px, -50px) rotate(180deg) scale(0.9); opacity: 0.15; }
    75% { transform: translate(-20px, -20px) rotate(270deg) scale(1); opacity: 0.25; }
    100% { transform: translate(0, 0) rotate(360deg) scale(0.8); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .particle, .particle-ring { animation: none !important; display: none; }
  }
</style>