---
import type { GameMeta } from '../../types/game';

interface Props {
  game: GameMeta;
  index?: number;
}

const { game, index = 0 } = Astro.props;
---

<a
  href={`/games/${game.slug}/`}
  class="game-card"
  style={`--card-index: ${index}; --glow-color: ${game.heroColor}`}
>
  <div class="game-card-bg"></div>

  <!-- Left: text -->
  <div class="game-card-left">
    <h3 class="game-card-title">{game.shortTitle}</h3>
    <p class="game-card-desc">{game.description}</p>
  </div>

  <!-- Right: icon -->
  <div class="game-card-right">
    <div class="game-card-icon-ring">
      <span class="game-card-icon">{game.icon}</span>
    </div>
  </div>

  <!-- Category badge — top-right corner -->
  <span class="game-card-badge">{game.category}</span>
</a>

<style>
  .game-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-4);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-5, 1.25rem) var(--space-5, 1.25rem);
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                border-color 0.4s ease,
                box-shadow 0.4s ease;
    animation: card-enter 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    animation-delay: calc(var(--card-index, 0) * 0.06s);
    opacity: 0;
  }

  @keyframes card-enter {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Radial glow from icon area */
  .game-card-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 85% 50%,
      var(--glow-color, rgba(0, 229, 255, 0.1)) 0%,
      transparent 55%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .game-card:hover {
    transform: translateY(-4px);
    border-color: var(--glow-color, var(--accent-cyan));
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.35),
      0 0 28px rgba(0, 229, 255, 0.05);
  }

  .game-card:hover .game-card-bg {
    opacity: 1;
  }

  /* ── Right: icon ── */
  .game-card-right {
    z-index: 1;
    flex-shrink: 0;
  }

  /* ── Category badge — top-right corner of card ── */
  .game-card-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 3;
    font-size: 0.6rem;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    background: var(--glow-color, var(--accent-cyan));
    border-radius: var(--radius-full);
    white-space: nowrap;
    pointer-events: none;
  }
  .game-card-left {
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .game-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .game-card-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .game-card-icon-ring {
    width: 100px;
    height: 100px;
    border-radius: var(--radius-lg);
    background: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.4s ease,
                box-shadow 0.4s ease,
                transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .game-card:hover .game-card-icon-ring {
    border-color: var(--glow-color, var(--accent-cyan));
    box-shadow: 0 0 24px rgba(0, 229, 255, 0.12);
    transform: scale(1.06);
  }

  .game-card-icon {
    font-size: 3rem;
    line-height: 1;
    animation: icon-float 4s ease-in-out infinite;
    animation-delay: calc(var(--card-index, 0) * 0.2s);
  }

  @keyframes icon-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .game-card {
      padding: var(--space-4);
      gap: var(--space-3);
    }
    .game-card-title { font-size: var(--text-base); }
    .game-card-icon-ring { width: 80px; height: 80px; }
    .game-card-icon { font-size: 2.5rem; }
  }

  @media (max-width: 480px) {
    .game-card-icon-ring { width: 64px; height: 64px; }
    .game-card-icon { font-size: 2rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .game-card { animation: none !important; opacity: 1; }
    .game-card-icon { animation: none !important; }
  }
</style>