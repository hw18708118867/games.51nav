{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "shortTitle": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "speed",
        "memory",
        "logic",
        "focus",
        "math",
        "visual",
        "word",
        "coordination",
        "knowledge",
        "casual"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard",
        "variable"
      ]
    },
    "order": {
      "type": "number"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heroColor": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "thumbnail": {
      "type": "string"
    },
    "componentName": {
      "type": "string"
    },
    "scoreType": {
      "type": "string",
      "enum": [
        "time",
        "score",
        "accuracy",
        "level",
        "wpm",
        "percentage"
      ]
    },
    "scoreUnit": {
      "type": "string"
    },
    "lowerIsBetter": {
      "default": false,
      "type": "boolean"
    },
    "hasLeaderboard": {
      "default": true,
      "type": "boolean"
    },
    "hasShare": {
      "default": true,
      "type": "boolean"
    },
    "hasTimer": {
      "default": false,
      "type": "boolean"
    },
    "faq": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        },
        "required": [
          "question",
          "answer"
        ]
      }
    },
    "tips": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tutorial": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": {
                "type": "number"
              },
              "instruction": {
                "type": "string"
              },
              "image": {
                "type": "string"
              }
            },
            "required": [
              "step",
              "instruction"
            ]
          }
        }
      },
      "required": [
        "title",
        "steps"
      ]
    },
    "relatedGames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "shortTitle",
    "slug",
    "description",
    "category",
    "difficulty",
    "order",
    "keywords",
    "heroColor",
    "icon",
    "componentName",
    "scoreType",
    "scoreUnit",
    "faq",
    "tips",
    "tutorial",
    "relatedGames"
  ]
}